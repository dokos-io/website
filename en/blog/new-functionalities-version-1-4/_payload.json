[{"data":1,"prerenderedAt":243},["Reactive",2],{"navigation":3,"/en/blog/new-functionalities-version-1-4":82,"/en/blog/new-functionalities-version-1-4-surround":241},[4,18,22,63,65,68,71,74,77,79],{"title":5,"_path":6,"children":7,"icon":17},"Docs","/docs",[8],{"title":9,"_path":10,"children":11},"Getting Started","/docs/getting-started",[12,14],{"title":13,"_path":10},"Introduction",{"title":15,"_path":16},"Installation","/docs/getting-started/installation","i-heroicons-book-open",{"title":19,"_path":20,"icon":21},"Pricing","/pricing","i-heroicons-credit-card",{"title":23,"_path":24,"children":25,"icon":62},"Blog","/blog",[26,29,32,35,38,41,44,47,50,53,56,59],{"title":27,"_path":28},"Dokos is available on DigitalOcean marketplace","/blog/digitalocean-marketplace",{"title":30,"_path":31},"Dokos, the new open-source ERP","/blog/dokos-new-open-source-erp",{"title":33,"_path":34},"Happy new year 2020","/blog/happy-new-year-2020",{"title":36,"_path":37},"Happy new year 2022","/blog/happy-new-year-2022",{"title":39,"_path":40},"Install party at l'Hermitage","/blog/install-party-hermitage",{"title":42,"_path":43},"New functionalities in version 1.1","/blog/new-functionalities-version-1-1",{"title":45,"_path":46},"New functionalities in version 1.2","/blog/new-functionalities-version-1-2",{"title":48,"_path":49},"New functionalities in version 1.3","/blog/new-functionalities-version-1-3",{"title":51,"_path":52},"New functionalities in version 1.4","/blog/new-functionalities-version-1-4",{"title":54,"_path":55},"New functionalities in version 2.0","/blog/new-functionalities-version-2-0",{"title":57,"_path":58},"New functionalities in version 2.1","/blog/new-functionalities-version-2-1",{"title":60,"_path":61},"New functionalities in version 2.2","/blog/new-functionalities-version-2-2","i-heroicons-newspaper",{"title":19,"_path":64,"icon":21},"/partners",{"title":66,"_path":67},"About us","/about",{"title":69,"_path":70},"Legal","/legal",{"title":72,"_path":73},"Security & Data Protection","/securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":52,"_dir":83,"_draft":84,"_partial":84,"_locale":85,"title":51,"description":86,"name":87,"year":88,"date":89,"id":90,"badge":91,"author":93,"image":94,"body":96,"_type":236,"_id":237,"_source":238,"_file":239,"_extension":240},"blog",false,"en","Linear depreciation over 360 days, demo translated in french, map view and data conservation when a document is renamed are available in v1.4.\n","new-functionalities-version-1-4","26st April 2020","2020-04-26","version-1-4",{"label":92},"News","Charles-Henri Decultot",{"src":95},"/blog/version-1-4/_main.jpg",{"type":97,"children":98,"toc":228},"root",[99,113,120,136,142,163,169,179,187,193,198,201,203,208,212],{"type":100,"tag":101,"props":102,"children":103},"element","p",{},[104,107,111],{"type":105,"value":106},"text","We are happy to offer you a minor Dokos update to wait while we work on a major udpate in the coming months.",{"type":100,"tag":108,"props":109,"children":110},"br",{},[],{"type":105,"value":112},"\nFour new main features are enriching the software.",{"type":100,"tag":114,"props":115,"children":117},"h2",{"id":116},"new-depreciation-method",[118],{"type":105,"value":119},"New depreciation method",{"type":100,"tag":101,"props":121,"children":122},{},[123,129,131,134],{"type":100,"tag":124,"props":125,"children":126},"em",{},[127],{"type":105,"value":128},"Dokos",{"type":105,"value":130}," can now calculate a linear depreciation with a prorata on 360 days.",{"type":100,"tag":108,"props":132,"children":133},{},[],{"type":105,"value":135},"\nIt was a missing functionality for France where it is the most commonly used depreciation method.",{"type":100,"tag":114,"props":137,"children":139},{"id":138},"the-demo-can-now-be-generated-in-french-and-in-english",[140],{"type":105,"value":141},"The demo can now be generated in french and in english",{"type":100,"tag":101,"props":143,"children":144},{},[145,147,151,153,156,158,161],{"type":105,"value":146},"It is now possible to choose the generation language of a demo of ",{"type":100,"tag":124,"props":148,"children":149},{},[150],{"type":105,"value":128},{"type":105,"value":152},".",{"type":100,"tag":108,"props":154,"children":155},{},[],{"type":105,"value":157},"\nAt this stage we have translated the original demo of ERPNext in french and plan on adding more localized data in the coming months.",{"type":100,"tag":108,"props":159,"children":160},{},[],{"type":105,"value":162},"\nThis technical step allows us also to add demo data in other languages as well in the future.",{"type":100,"tag":114,"props":164,"children":166},{"id":165},"map-view",[167],{"type":105,"value":168},"Map view",{"type":100,"tag":101,"props":170,"children":171},{},[172,174,177],{"type":105,"value":173},"A new type of view \"Map\" can display your addresses on a world map and apply all the filters you need like with any other view.",{"type":100,"tag":108,"props":175,"children":176},{},[],{"type":105,"value":178},"\nThis new view necessitates the activation of the Google Maps API to fetch the geolocalisation data for each address.",{"type":100,"tag":101,"props":180,"children":181},{},[182],{"type":100,"tag":183,"props":184,"children":186},"img",{"alt":168,"src":185},"/assets/images/blog/version-1-4/map_view.png",[],{"type":100,"tag":114,"props":188,"children":190},{"id":189},"registration-of-a-renamed-document",[191],{"type":105,"value":192},"Registration of a renamed document",{"type":100,"tag":101,"props":194,"children":195},{},[196],{"type":105,"value":197},"Now, whenever a document is renamed, this information is conserved in a new type of document - Renamed document - that can be easily queried for audit purposes.",{"type":100,"tag":108,"props":199,"children":200},{},[],{"type":105,"value":202},"  \n",{"type":100,"tag":101,"props":204,"children":205},{},[206],{"type":105,"value":207},"The Digital Ocean image for this new version will be available soon and the update on our cloud will be rolled out in the coming days.",{"type":100,"tag":209,"props":210,"children":211},"hr",{},[],{"type":100,"tag":101,"props":213,"children":214},{},[215,217,226],{"type":105,"value":216},"Our ",{"type":100,"tag":218,"props":219,"children":223},"a",{"href":220,"rel":221},"https://gitlab.com/dokos/dokos/-/boards/966503",[222],"nofollow",[224],{"type":105,"value":225},"roadmap",{"type":105,"value":227}," is available, so don't hesitate to comment, suggest and propose concrete solutions to help us put this software on the right tracks.",{"title":229,"searchDepth":230,"depth":230,"links":231},"",2,[232,233,234,235],{"id":116,"depth":230,"text":119},{"id":138,"depth":230,"text":141},{"id":165,"depth":230,"text":168},{"id":189,"depth":230,"text":192},"markdown","content:en:blog:new-functionalities-version-1-4.md","content","en/blog/new-functionalities-version-1-4.md","md",[242,242],null,1714114105769]