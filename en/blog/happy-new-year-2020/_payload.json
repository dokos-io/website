[{"data":1,"prerenderedAt":240},["Reactive",2],{"navigation":3,"/en/blog/happy-new-year-2020":82,"/en/blog/happy-new-year-2020-surround":238},[4,18,22,63,65,68,71,74,77,79],{"title":5,"_path":6,"children":7,"icon":17},"Docs","/docs",[8],{"title":9,"_path":10,"children":11},"Getting Started","/docs/getting-started",[12,14],{"title":13,"_path":10},"Introduction",{"title":15,"_path":16},"Installation","/docs/getting-started/installation","i-heroicons-book-open",{"title":19,"_path":20,"icon":21},"Pricing","/pricing","i-heroicons-credit-card",{"title":23,"_path":24,"children":25,"icon":62},"Blog","/blog",[26,29,32,35,38,41,44,47,50,53,56,59],{"title":27,"_path":28},"Dokos is available on DigitalOcean marketplace","/blog/digitalocean-marketplace",{"title":30,"_path":31},"Dokos, the new open-source ERP","/blog/dokos-new-open-source-erp",{"title":33,"_path":34},"Happy new year 2020","/blog/happy-new-year-2020",{"title":36,"_path":37},"Happy new year 2022","/blog/happy-new-year-2022",{"title":39,"_path":40},"Install party at l'Hermitage","/blog/install-party-hermitage",{"title":42,"_path":43},"New functionalities in version 1.1","/blog/new-functionalities-version-1-1",{"title":45,"_path":46},"New functionalities in version 1.2","/blog/new-functionalities-version-1-2",{"title":48,"_path":49},"New functionalities in version 1.3","/blog/new-functionalities-version-1-3",{"title":51,"_path":52},"New functionalities in version 1.4","/blog/new-functionalities-version-1-4",{"title":54,"_path":55},"New functionalities in version 2.0","/blog/new-functionalities-version-2-0",{"title":57,"_path":58},"New functionalities in version 2.1","/blog/new-functionalities-version-2-1",{"title":60,"_path":61},"New functionalities in version 2.2","/blog/new-functionalities-version-2-2","i-heroicons-newspaper",{"title":19,"_path":64,"icon":21},"/partners",{"title":66,"_path":67},"About us","/about",{"title":69,"_path":70},"Legal","/legal",{"title":72,"_path":73},"Security & Data Protection","/securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":34,"_dir":83,"_draft":84,"_partial":84,"_locale":85,"title":33,"description":86,"name":87,"year":88,"date":89,"id":90,"badge":91,"author":93,"image":94,"body":96,"_type":233,"_id":234,"_source":235,"_file":236,"_extension":237},"blog",false,"en","Happy new year from the Dokos team ! 🎊\n","happy-new-year-2020","31 december 2019","2019-12-31","new-year-2020",{"label":92},"News","Charles-Henri Decultot",{"src":95},"/blog/new-year-2020/_main.jpg",{"type":97,"children":98,"toc":229},"root",[99,107,142,179,213,224],{"type":100,"tag":101,"props":102,"children":103},"element","p",{},[104],{"type":105,"value":106},"text","As the year comes to an end, it's time to make a quick update before the start of a new exciting decade !",{"type":100,"tag":101,"props":108,"children":109},{},[110,112,118,120,124,126,129,131,135,137,140],{"type":105,"value":111},"2019 has been a pivotal year, with the creation of ",{"type":100,"tag":113,"props":114,"children":115},"strong",{},[116],{"type":105,"value":117},"Dokos",{"type":105,"value":119}," and its official launch last october.",{"type":100,"tag":121,"props":122,"children":123},"br",{},[],{"type":105,"value":125},"\nYou are already a few dozens of companies to trust us and use the software to manage your daily activity and we thank you from the bottom of our heart.",{"type":100,"tag":121,"props":127,"children":128},{},[],{"type":105,"value":130},"\nThe first three versions of ",{"type":100,"tag":113,"props":132,"children":133},{},[134],{"type":105,"value":117},{"type":105,"value":136}," have already brought improvements to a certain number of functionalities, like the user interface, the calendars, the notification center or the subscriptions and their integration with Stripe and GoCardless.",{"type":100,"tag":121,"props":138,"children":139},{},[],{"type":105,"value":141},"\nWe have also been able to create new functionalities like the item bookings. They already help several Shared Places manage their space and resources reservations successfully.",{"type":100,"tag":101,"props":143,"children":144},{},[145,147,150,152,155,157,160,162,166,168,171,173,177],{"type":105,"value":146},"The work has just started and we have already several big projects planned for 2020.",{"type":100,"tag":121,"props":148,"children":149},{},[],{"type":105,"value":151},"\nIn the beginning of the year, priority will be given to the improvement of accounting processes to facilitate inputs, reduce error risks and improve the closing process.",{"type":100,"tag":121,"props":153,"children":154},{},[],{"type":105,"value":156},"\nLocal functionalities, in particular functionalities specific to France, are also expected during the year.",{"type":100,"tag":121,"props":158,"children":159},{},[],{"type":105,"value":161},"\nWe also wish to make ",{"type":100,"tag":113,"props":163,"children":164},{},[165],{"type":105,"value":117},{"type":105,"value":167}," installation process easier to enable the largest number of people to install and use it to manage their company.",{"type":100,"tag":121,"props":169,"children":170},{},[],{"type":105,"value":172},"\nAll of this without forgetting multiple improvements in each of the 33 modules composing ",{"type":100,"tag":113,"props":174,"children":175},{},[176],{"type":105,"value":117},{"type":105,"value":178},".",{"type":100,"tag":101,"props":180,"children":181},{},[182,184,187,189,198,200,203,205,211],{"type":105,"value":183},"Our main objective is first and foremost to help your solve problems your run into in your daily activity.",{"type":100,"tag":121,"props":185,"children":186},{},[],{"type":105,"value":188},"\nThat is why our ",{"type":100,"tag":190,"props":191,"children":195},"a",{"href":192,"rel":193},"https://gitlab.com/dokos/dokos/-/boards/966503",[194],"nofollow",[196],{"type":105,"value":197},"roadmap",{"type":105,"value":199}," is dynamic and collaborative.",{"type":100,"tag":121,"props":201,"children":202},{},[],{"type":105,"value":204},"\nParticipate to its ",{"type":100,"tag":190,"props":206,"children":208},{"href":192,"rel":207},[194],[209],{"type":105,"value":210},"construction",{"type":105,"value":212},", vote for the most important functionalities for you and we will do our best to improve the software based on your needs.",{"type":100,"tag":101,"props":214,"children":215},{},[216,218,222],{"type":105,"value":217},"It is only thanks to your investment that we will be able to build a bigger open-source community around ",{"type":100,"tag":113,"props":219,"children":220},{},[221],{"type":105,"value":117},{"type":105,"value":223}," in 2020 !",{"type":100,"tag":101,"props":225,"children":226},{},[227],{"type":105,"value":228},"We wish you a very happy new year !!! 🎊",{"title":230,"searchDepth":231,"depth":231,"links":232},"",2,[],"markdown","content:en:blog:happy-new-year-2020.md","content","en/blog/happy-new-year-2020.md","md",[239,239],null,1714114105813]