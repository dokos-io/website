[{"data":1,"prerenderedAt":266},["Reactive",2],{"navigation":3,"/en/blog/new-functionalities-version-2-0":82,"/en/blog/new-functionalities-version-2-0-surround":264},[4,18,22,63,65,68,71,74,77,79],{"title":5,"_path":6,"children":7,"icon":17},"Docs","/docs",[8],{"title":9,"_path":10,"children":11},"Getting Started","/docs/getting-started",[12,14],{"title":13,"_path":10},"Introduction",{"title":15,"_path":16},"Installation","/docs/getting-started/installation","i-heroicons-book-open",{"title":19,"_path":20,"icon":21},"Pricing","/pricing","i-heroicons-credit-card",{"title":23,"_path":24,"children":25,"icon":62},"Blog","/blog",[26,29,32,35,38,41,44,47,50,53,56,59],{"title":27,"_path":28},"Dokos is available on DigitalOcean marketplace","/blog/digitalocean-marketplace",{"title":30,"_path":31},"Dokos, the new open-source ERP","/blog/dokos-new-open-source-erp",{"title":33,"_path":34},"Happy new year 2020","/blog/happy-new-year-2020",{"title":36,"_path":37},"Happy new year 2022","/blog/happy-new-year-2022",{"title":39,"_path":40},"Install party at l'Hermitage","/blog/install-party-hermitage",{"title":42,"_path":43},"New functionalities in version 1.1","/blog/new-functionalities-version-1-1",{"title":45,"_path":46},"New functionalities in version 1.2","/blog/new-functionalities-version-1-2",{"title":48,"_path":49},"New functionalities in version 1.3","/blog/new-functionalities-version-1-3",{"title":51,"_path":52},"New functionalities in version 1.4","/blog/new-functionalities-version-1-4",{"title":54,"_path":55},"New functionalities in version 2.0","/blog/new-functionalities-version-2-0",{"title":57,"_path":58},"New functionalities in version 2.1","/blog/new-functionalities-version-2-1",{"title":60,"_path":61},"New functionalities in version 2.2","/blog/new-functionalities-version-2-2","i-heroicons-newspaper",{"title":19,"_path":64,"icon":21},"/partners",{"title":66,"_path":67},"About us","/about",{"title":69,"_path":70},"Legal","/legal",{"title":72,"_path":73},"Security & Data Protection","/securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":55,"_dir":83,"_draft":84,"_partial":84,"_locale":85,"title":54,"description":86,"name":87,"year":88,"date":89,"id":90,"badge":91,"author":93,"image":94,"body":96,"_type":259,"_id":260,"_source":261,"_file":262,"_extension":263},"blog",false,"en","Supplier quote comparison, WooCommerce, LinkedIn, Twitter, YouTube integrations, French accounting standards, automated vacations, production planning\n","new-functionalities-version-2-0","June 17, 2021","2021-06-17","version-2-0",{"label":92},"News","Nicolas Tissot",{"src":95},"/blog/version-2-0/_main.jpg",{"type":97,"children":98,"toc":246},"root",[99,107,114,119,125,130,136,141,146,152,157,163,168,174,179,185,190,196,201,207,212,216,232],{"type":100,"tag":101,"props":102,"children":103},"element","p",{},[104],{"type":105,"value":106},"text","For this new version of Dokos, many changes have been made to all the modules, especially in the user interface.",{"type":100,"tag":108,"props":109,"children":111},"h2",{"id":110},"comparison-of-supplier-quotes",[112],{"type":105,"value":113},"Comparison of supplier quotes",{"type":100,"tag":101,"props":115,"children":116},{},[117],{"type":105,"value":118},"From now on, you will be able to compare supplier quotes on Dokos and scan barcodes in purchase receipts.\nYou will also be able to manage multiple units of measure in your tenders.",{"type":100,"tag":108,"props":120,"children":122},{"id":121},"display-of-the-balance-sheet-according-to-french-standards",[123],{"type":105,"value":124},"Display of the balance sheet according to French standards",{"type":100,"tag":101,"props":126,"children":127},{},[128],{"type":105,"value":129},"The display of the balance sheet according to French standards for French companies.\nIn addition, a new option has been added: the down payment invoice becomes possible in the invoicing options.",{"type":100,"tag":108,"props":131,"children":133},{"id":132},"better-integrations-woocommerce-social-networks",[134],{"type":105,"value":135},"Better integrations: WooCommerce, social networks",{"type":100,"tag":101,"props":137,"children":138},{},[139],{"type":105,"value":140},"The arrival of a new WooCommerce connector for your online store (stock management, VAT, invoices) improves the synchronization between your store and Dokos.",{"type":100,"tag":101,"props":142,"children":143},{},[144],{"type":105,"value":145},"You also have the possibility to configure posts for your social networks LinkedIn, Twitter and even see your statistics on YouTube.",{"type":100,"tag":108,"props":147,"children":149},{"id":148},"new-printing-options",[150],{"type":105,"value":151},"New printing options",{"type":100,"tag":101,"props":153,"children":154},{},[155],{"type":105,"value":156},"New printing options are available for your transactional documents in Dokos (Quote, Order, Invoice).",{"type":100,"tag":108,"props":158,"children":160},{"id":159},"a-new-location-module",[161],{"type":105,"value":162},"A new Location module",{"type":100,"tag":101,"props":164,"children":165},{},[166],{"type":105,"value":167},"This new module allows you to reserve items, with the ability to confirm the reservation of the item as soon as the payment is processed.",{"type":100,"tag":108,"props":169,"children":171},{"id":170},"customizable-sales-rules",[172],{"type":105,"value":173},"Customizable sales rules",{"type":100,"tag":101,"props":175,"children":176},{},[177],{"type":105,"value":178},"New features to boost your sales offers by adding price rules and recursive rules (2 bought, 1 free for example).",{"type":100,"tag":108,"props":180,"children":182},{"id":181},"better-tracking-of-your-shipments",[183],{"type":105,"value":184},"Better tracking of your shipments",{"type":100,"tag":101,"props":186,"children":187},{},[188],{"type":105,"value":189},"New type of document Shipping in which the configuration of shipping parameters is possible. Integration with parcel shipping gateways.",{"type":100,"tag":108,"props":191,"children":193},{"id":192},"automate-your-teams-vacations",[194],{"type":105,"value":195},"Automate your team's vacations",{"type":100,"tag":101,"props":197,"children":198},{},[199],{"type":105,"value":200},"You can now automatically allocate leave based on a leave policy.\nOther new human resources management features are available: promise to hire and partially paid leave.",{"type":100,"tag":108,"props":202,"children":204},{"id":203},"more-efficient-manufacturing-process",[205],{"type":105,"value":206},"More efficient manufacturing process",{"type":100,"tag":101,"props":208,"children":209},{},[210],{"type":105,"value":211},"Schedule the production of sales orders, material requests and work orders.\nIn addition, you have the ability to create BOM templates for your production.",{"type":100,"tag":213,"props":214,"children":215},"br",{},[],{"type":100,"tag":101,"props":217,"children":218},{},[219,221,230],{"type":105,"value":220},"You can find the detailed list of changes in this new update in the ",{"type":100,"tag":222,"props":223,"children":227},"a",{"href":224,"rel":225},"https://doc.dokos.io/en/versions/v2_0_0",[226],"nofollow",[228],{"type":105,"value":229},"technical documentation",{"type":105,"value":231},".",{"type":100,"tag":101,"props":233,"children":234},{},[235,237,244],{"type":105,"value":236},"Our ",{"type":100,"tag":222,"props":238,"children":241},{"href":239,"rel":240},"https://gitlab.com/dokos/dokos/-/boards/966503",[226],[242],{"type":105,"value":243},"roadmap",{"type":105,"value":245}," is accessible to everyone, so don't hesitate to comment, suggest and propose concrete solutions to help us make this software evolve in the right direction.",{"title":247,"searchDepth":248,"depth":248,"links":249},"",2,[250,251,252,253,254,255,256,257,258],{"id":110,"depth":248,"text":113},{"id":121,"depth":248,"text":124},{"id":132,"depth":248,"text":135},{"id":148,"depth":248,"text":151},{"id":159,"depth":248,"text":162},{"id":170,"depth":248,"text":173},{"id":181,"depth":248,"text":184},{"id":192,"depth":248,"text":195},{"id":203,"depth":248,"text":206},"markdown","content:en:blog:new-functionalities-version-2-0.md","content","en/blog/new-functionalities-version-2-0.md","md",[265,265],null,1714114105758]