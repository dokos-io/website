[{"data":1,"prerenderedAt":255},["Reactive",2],{"navigation":3,"/en/blog/new-functionalities-version-2-2":82,"/en/blog/new-functionalities-version-2-2-surround":253},[4,18,22,63,65,68,71,74,77,79],{"title":5,"_path":6,"children":7,"icon":17},"Docs","/docs",[8],{"title":9,"_path":10,"children":11},"Getting Started","/docs/getting-started",[12,14],{"title":13,"_path":10},"Introduction",{"title":15,"_path":16},"Installation","/docs/getting-started/installation","i-heroicons-book-open",{"title":19,"_path":20,"icon":21},"Pricing","/pricing","i-heroicons-credit-card",{"title":23,"_path":24,"children":25,"icon":62},"Blog","/blog",[26,29,32,35,38,41,44,47,50,53,56,59],{"title":27,"_path":28},"Dokos is available on DigitalOcean marketplace","/blog/digitalocean-marketplace",{"title":30,"_path":31},"Dokos, the new open-source ERP","/blog/dokos-new-open-source-erp",{"title":33,"_path":34},"Happy new year 2020","/blog/happy-new-year-2020",{"title":36,"_path":37},"Happy new year 2022","/blog/happy-new-year-2022",{"title":39,"_path":40},"Install party at l'Hermitage","/blog/install-party-hermitage",{"title":42,"_path":43},"New functionalities in version 1.1","/blog/new-functionalities-version-1-1",{"title":45,"_path":46},"New functionalities in version 1.2","/blog/new-functionalities-version-1-2",{"title":48,"_path":49},"New functionalities in version 1.3","/blog/new-functionalities-version-1-3",{"title":51,"_path":52},"New functionalities in version 1.4","/blog/new-functionalities-version-1-4",{"title":54,"_path":55},"New functionalities in version 2.0","/blog/new-functionalities-version-2-0",{"title":57,"_path":58},"New functionalities in version 2.1","/blog/new-functionalities-version-2-1",{"title":60,"_path":61},"New functionalities in version 2.2","/blog/new-functionalities-version-2-2","i-heroicons-newspaper",{"title":19,"_path":64,"icon":21},"/partners",{"title":66,"_path":67},"About us","/about",{"title":69,"_path":70},"Legal","/legal",{"title":72,"_path":73},"Security & Data Protection","/securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":61,"_dir":83,"_draft":84,"_partial":84,"_locale":85,"title":60,"description":86,"name":87,"year":88,"date":89,"id":90,"badge":91,"author":93,"image":94,"body":96,"_type":248,"_id":249,"_source":250,"_file":251,"_extension":252},"blog",false,"en","New features on subscription management and new integrations with collaborative tools.\n","new-functionalities-version-2-2","october 8, 2021","2021-10-08","version-2-2",{"label":92},"News","Nicolas Tissot",{"src":95},"/blog/version-2-2/_main.jpg",{"type":97,"children":98,"toc":235},"root",[99,107,114,121,126,132,137,143,148,154,159,179,191,196,201,205,221],{"type":100,"tag":101,"props":102,"children":103},"element","p",{},[104],{"type":105,"value":106},"text","For this new update of Dokos, small changes are to be noted like improvements on the management of subscriptions and new collaborative tools that can be connected.",{"type":100,"tag":108,"props":109,"children":111},"h2",{"id":110},"improvements-in-subscription-management",[112],{"type":105,"value":113},"Improvements in subscription management",{"type":100,"tag":115,"props":116,"children":118},"h3",{"id":117},"create-a-subscription-from-a-sales-order",[119],{"type":105,"value":120},"Create a subscription from a sales order",{"type":100,"tag":101,"props":122,"children":123},{},[124],{"type":105,"value":125},"You have the ability to link an item to a subscription template. This will allow you to automatically create a subscription from the sales order, either from the website or from the desktop if the order is of type Shipping Cart.",{"type":100,"tag":115,"props":127,"children":129},{"id":128},"_2-modifying-your-subscription-from-the-website",[130],{"type":105,"value":131},"2. Modifying your subscription from the website",{"type":100,"tag":101,"props":133,"children":134},{},[135],{"type":105,"value":136},"From now on, it is possible to add or remove an option to one of your subscriptions. This allows your users to have more flexibility in managing their subscription(s).",{"type":100,"tag":115,"props":138,"children":140},{"id":139},"_3-ability-to-manage-multiple-subscriptions-per-user",[141],{"type":105,"value":142},"3. Ability to manage multiple subscriptions per user",{"type":100,"tag":101,"props":144,"children":145},{},[146],{"type":105,"value":147},"From the customer portal, it is now possible to manage multiple subscriptions per user. Previously, only the last subscription was displayed in the subscriptions section of your users.",{"type":100,"tag":108,"props":149,"children":151},{"id":150},"new-features-in-the-integrations",[152],{"type":105,"value":153},"New features in the integrations",{"type":100,"tag":101,"props":155,"children":156},{},[157],{"type":105,"value":158},"It is now possible to send notifications via the following collaborative tools:",{"type":100,"tag":160,"props":161,"children":162},"ul",{},[163,169,174],{"type":100,"tag":164,"props":165,"children":166},"li",{},[167],{"type":105,"value":168},"Google Chat",{"type":100,"tag":164,"props":170,"children":171},{},[172],{"type":105,"value":173},"Mattermost",{"type":100,"tag":164,"props":175,"children":176},{},[177],{"type":105,"value":178},"Rocket.Chat",{"type":100,"tag":108,"props":180,"children":182},{"id":181},"possibility-to-activate-the-order-validation-without-payment-gateway-website",[183,185],{"type":105,"value":184},"Possibility to activate the order validation without payment gateway ",{"type":100,"tag":186,"props":187,"children":188},"span",{},[189],{"type":105,"value":190},"WEBSITE",{"type":100,"tag":101,"props":192,"children":193},{},[194],{"type":105,"value":195},"For the customer portal part, it is now possible to enable checkout without payment gateway. This allows you to receive orders from your users without them having made the payment.",{"type":100,"tag":101,"props":197,"children":198},{},[199],{"type":105,"value":200},"Before this, there had to be a gateway activated (Bank transfer, Stripe etc..) or the user could validate his request by sending a quotation request.",{"type":100,"tag":202,"props":203,"children":204},"br",{},[],{"type":100,"tag":101,"props":206,"children":207},{},[208,210,219],{"type":105,"value":209},"You can find the detailed list of changes in this new update in the ",{"type":100,"tag":211,"props":212,"children":216},"a",{"href":213,"rel":214},"https://doc.dokos.io/en/versions/v2_2_0",[215],"nofollow",[217],{"type":105,"value":218},"technical documentation",{"type":105,"value":220},".",{"type":100,"tag":101,"props":222,"children":223},{},[224,226,233],{"type":105,"value":225},"Our ",{"type":100,"tag":211,"props":227,"children":230},{"href":228,"rel":229},"https://gitlab.com/dokos/dokos/-/boards/966503",[215],[231],{"type":105,"value":232},"roadmap",{"type":105,"value":234}," is accessible to everyone, so don't hesitate to comment, suggest and propose concrete solutions to help us make this software evolve in the right direction.",{"title":236,"searchDepth":237,"depth":237,"links":238},"",2,[239,245,246],{"id":110,"depth":237,"text":113,"children":240},[241,243,244],{"id":117,"depth":242,"text":120},3,{"id":128,"depth":242,"text":131},{"id":139,"depth":242,"text":142},{"id":150,"depth":237,"text":153},{"id":181,"depth":237,"text":247},"Possibility to activate the order validation without payment gateway WEBSITE","markdown","content:en:blog:new-functionalities-version-2-2.md","content","en/blog/new-functionalities-version-2-2.md","md",[254,254],null,1714114105691]