[{"data":1,"prerenderedAt":223},["Reactive",2],{"navigation":3,"/en/blog/new-functionalities-version-2-1":82,"/en/blog/new-functionalities-version-2-1-surround":221},[4,18,22,63,65,68,71,74,77,79],{"title":5,"_path":6,"children":7,"icon":17},"Docs","/docs",[8],{"title":9,"_path":10,"children":11},"Getting Started","/docs/getting-started",[12,14],{"title":13,"_path":10},"Introduction",{"title":15,"_path":16},"Installation","/docs/getting-started/installation","i-heroicons-book-open",{"title":19,"_path":20,"icon":21},"Pricing","/pricing","i-heroicons-credit-card",{"title":23,"_path":24,"children":25,"icon":62},"Blog","/blog",[26,29,32,35,38,41,44,47,50,53,56,59],{"title":27,"_path":28},"Dokos is available on DigitalOcean marketplace","/blog/digitalocean-marketplace",{"title":30,"_path":31},"Dokos, the new open-source ERP","/blog/dokos-new-open-source-erp",{"title":33,"_path":34},"Happy new year 2020","/blog/happy-new-year-2020",{"title":36,"_path":37},"Happy new year 2022","/blog/happy-new-year-2022",{"title":39,"_path":40},"Install party at l'Hermitage","/blog/install-party-hermitage",{"title":42,"_path":43},"New functionalities in version 1.1","/blog/new-functionalities-version-1-1",{"title":45,"_path":46},"New functionalities in version 1.2","/blog/new-functionalities-version-1-2",{"title":48,"_path":49},"New functionalities in version 1.3","/blog/new-functionalities-version-1-3",{"title":51,"_path":52},"New functionalities in version 1.4","/blog/new-functionalities-version-1-4",{"title":54,"_path":55},"New functionalities in version 2.0","/blog/new-functionalities-version-2-0",{"title":57,"_path":58},"New functionalities in version 2.1","/blog/new-functionalities-version-2-1",{"title":60,"_path":61},"New functionalities in version 2.2","/blog/new-functionalities-version-2-2","i-heroicons-newspaper",{"title":19,"_path":64,"icon":21},"/partners",{"title":66,"_path":67},"About us","/about",{"title":69,"_path":70},"Legal","/legal",{"title":72,"_path":73},"Security & Data Protection","/securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":58,"_dir":83,"_draft":84,"_partial":84,"_locale":85,"title":57,"description":86,"name":87,"year":88,"date":89,"id":90,"badge":91,"author":93,"image":94,"body":96,"_type":216,"_id":217,"_source":218,"_file":219,"_extension":220},"blog",false,"en","New features and updates on Dokos: Compatibility, Purchasing, Dodock Framework, HR, Projects, Sales and Inventory.\n","new-functionalities-version-2-1","September 8, 2021","2021-09-08","version-2-1",{"label":92},"News","Nicolas Tissot",{"src":95},"/blog/version-2-1/_main.jpg",{"type":97,"children":98,"toc":207},"root",[99,107,114,119,125,130,136,141,146,152,157,163,168,173,177,193],{"type":100,"tag":101,"props":102,"children":103},"element","p",{},[104],{"type":105,"value":106},"text","For this new update of Dokos, some changes are to be noted on several modules including accounting, sales, purchases, inventory, projects and Human Resources.",{"type":100,"tag":108,"props":109,"children":111},"h2",{"id":110},"creating-a-multilingual-site",[112],{"type":105,"value":113},"Creating a multilingual site",{"type":100,"tag":101,"props":115,"children":116},{},[117],{"type":105,"value":118},"You now have the possibility to create your website in several languages. A language selector can be displayed on the site to allow users to choose their preferred language.",{"type":100,"tag":108,"props":120,"children":122},{"id":121},"display-of-available-stock-in-supplier-orders",[123],{"type":105,"value":124},"Display of available stock in supplier orders",{"type":100,"tag":101,"props":126,"children":127},{},[128],{"type":105,"value":129},"From the supplier orders, you now have a field that displays the total stock on hand. Until now you had to go to your inventory and view the stock on the item to see the availability.",{"type":100,"tag":108,"props":131,"children":133},{"id":132},"create-purchase-receipts-faster",[134],{"type":105,"value":135},"Create purchase receipts faster",{"type":100,"tag":101,"props":137,"children":138},{},[139],{"type":105,"value":140},"When you physically receive goods, raw materials, etc., you need to enter a receipt. This receipt will usually be linked to a purchase order or a purchase invoice.",{"type":100,"tag":101,"props":142,"children":143},{},[144],{"type":105,"value":145},"Purchase receipts can now be created from your purchase invoices.\nNo need to manually create your purchase receipt following a receipt. Make your purchase invoice and generate the purchase receipt simply.",{"type":100,"tag":108,"props":147,"children":149},{"id":148},"new-reports-for-your-projects",[150],{"type":105,"value":151},"New reports for your projects",{"type":100,"tag":101,"props":153,"children":154},{},[155],{"type":105,"value":156},"Generate new reports to manage your projects. View the profitability of a project and see the hours used by employees.",{"type":100,"tag":108,"props":158,"children":160},{"id":159},"document-sharing-and-user-type-creation-for-hr",[161],{"type":105,"value":162},"Document sharing and user type creation for HR",{"type":100,"tag":101,"props":164,"children":165},{},[166],{"type":105,"value":167},"In the Human Resources module, you have the ability to share the document with employee approvers even if they do not have access to the document.",{"type":100,"tag":101,"props":169,"children":170},{},[171],{"type":105,"value":172},"Moreover, you can create a specific user type only for employees who need to access the system for the HR part.",{"type":100,"tag":174,"props":175,"children":176},"br",{},[],{"type":100,"tag":101,"props":178,"children":179},{},[180,182,191],{"type":105,"value":181},"You can find the detailed list of changes in this new update in the ",{"type":100,"tag":183,"props":184,"children":188},"a",{"href":185,"rel":186},"https://doc.dokos.io/en/versions/v2_1_0",[187],"nofollow",[189],{"type":105,"value":190},"technical documentation",{"type":105,"value":192},".",{"type":100,"tag":101,"props":194,"children":195},{},[196,198,205],{"type":105,"value":197},"Our ",{"type":100,"tag":183,"props":199,"children":202},{"href":200,"rel":201},"https://gitlab.com/dokos/dokos/-/boards/966503",[187],[203],{"type":105,"value":204},"roadmap",{"type":105,"value":206}," is accessible to everyone, so don't hesitate to comment, suggest and propose concrete solutions to help us make this software evolve in the right direction.",{"title":208,"searchDepth":209,"depth":209,"links":210},"",2,[211,212,213,214,215],{"id":110,"depth":209,"text":113},{"id":121,"depth":209,"text":124},{"id":132,"depth":209,"text":135},{"id":148,"depth":209,"text":151},{"id":159,"depth":209,"text":162},"markdown","content:en:blog:new-functionalities-version-2-1.md","content","en/blog/new-functionalities-version-2-1.md","md",[222,222],null,1714114105695]