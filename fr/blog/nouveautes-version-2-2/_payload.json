[{"data":1,"prerenderedAt":261},["Reactive",2],{"navigation":3,"/fr/blog/nouveautes-version-2-2":82,"/fr/blog/nouveautes-version-2-2-surround":259},[4,18,22,63,65,68,71,74,77,79],{"title":5,"_path":6,"children":7,"icon":17},"Docs","/docs",[8],{"title":9,"_path":10,"children":11},"Getting Started","/docs/getting-started",[12,14],{"title":13,"_path":10},"Introduction",{"title":15,"_path":16},"Installation","/docs/getting-started/installation","i-heroicons-book-open",{"title":19,"_path":20,"icon":21},"Pricing","/pricing","i-heroicons-credit-card",{"title":23,"_path":24,"children":25,"icon":62},"Blog","/blog",[26,29,32,35,38,41,44,47,50,53,56,59],{"title":27,"_path":28},"Dokos is available on DigitalOcean marketplace","/blog/digitalocean-marketplace",{"title":30,"_path":31},"Dokos, the new open-source ERP","/blog/dokos-new-open-source-erp",{"title":33,"_path":34},"Happy new year 2020","/blog/happy-new-year-2020",{"title":36,"_path":37},"Happy new year 2022","/blog/happy-new-year-2022",{"title":39,"_path":40},"Install party at l'Hermitage","/blog/install-party-hermitage",{"title":42,"_path":43},"New functionalities in version 1.1","/blog/new-functionalities-version-1-1",{"title":45,"_path":46},"New functionalities in version 1.2","/blog/new-functionalities-version-1-2",{"title":48,"_path":49},"New functionalities in version 1.3","/blog/new-functionalities-version-1-3",{"title":51,"_path":52},"New functionalities in version 1.4","/blog/new-functionalities-version-1-4",{"title":54,"_path":55},"New functionalities in version 2.0","/blog/new-functionalities-version-2-0",{"title":57,"_path":58},"New functionalities in version 2.1","/blog/new-functionalities-version-2-1",{"title":60,"_path":61},"New functionalities in version 2.2","/blog/new-functionalities-version-2-2","i-heroicons-newspaper",{"title":19,"_path":64,"icon":21},"/partners",{"title":66,"_path":67},"About us","/about",{"title":69,"_path":70},"Legal","/legal",{"title":72,"_path":73},"Security & Data Protection","/securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":83,"_dir":84,"_draft":85,"_partial":85,"_locale":86,"title":87,"description":88,"name":89,"year":90,"date":91,"id":92,"badge":93,"author":95,"image":96,"body":98,"_type":254,"_id":255,"_source":256,"_file":257,"_extension":258},"/blog/nouveautes-version-2-2","blog",false,"fr","Nouveautés de la version 2.2 de Dokos","Des nouveautés sur la gestion des abonnements et des nouvelles intégrations avec des outils collaboratifs.\n","nouveautes-version-2-2","8 octobre 2021","2021-10-08","version-2-2",{"label":94},"Actualités","Nicolas Tissot",{"src":97},"/blog/version-2-2/_main.jpg",{"type":99,"children":100,"toc":241},"root",[101,109,116,123,128,134,139,145,150,156,161,181,193,198,203,207,223,227],{"type":102,"tag":103,"props":104,"children":105},"element","p",{},[106],{"type":107,"value":108},"text","Pour cette nouvelle mise à jour de Dokos, des petits changements sont à noter comme des améliorations sur la gestion des abonnements et de nouveaux outils collaboratifs qui peuvent être connectés.",{"type":102,"tag":110,"props":111,"children":113},"h2",{"id":112},"des-améliorations-sur-la-gestion-des-abonnements",[114],{"type":107,"value":115},"Des améliorations sur la gestion des abonnements",{"type":102,"tag":117,"props":118,"children":120},"h3",{"id":119},"_1-créer-un-abonnement-depuis-une-commande-client",[121],{"type":107,"value":122},"1. Créer un abonnement depuis une commande client",{"type":102,"tag":103,"props":124,"children":125},{},[126],{"type":107,"value":127},"Vous avez la possibilité de lier un article à un modèle d'abonnement. Cela vous permettra de créer automatiquement un abonnement à partir de la commande client, soit depuis le site web, soit depuis le bureau si la commande est de type PANIER.",{"type":102,"tag":117,"props":129,"children":131},{"id":130},"_2-modification-de-votre-abonnement-depuis-le-site-web",[132],{"type":107,"value":133},"2. Modification de votre abonnement depuis le site web",{"type":102,"tag":103,"props":135,"children":136},{},[137],{"type":107,"value":138},"Dès à présent, il est possible d'ajouter ou supprimer une option à l'un de vos abonnements. Cela permet d'avoir plus de flexibilité pour vos utilisateurs quant à la gestion de leur(s) abonnement(s).",{"type":102,"tag":117,"props":140,"children":142},{"id":141},"_3-possibilité-de-gérer-plusieurs-abonnements-par-utilisateur",[143],{"type":107,"value":144},"3. Possibilité de gérer plusieurs abonnements par utilisateur",{"type":102,"tag":103,"props":146,"children":147},{},[148],{"type":107,"value":149},"Depuis le portail client, il est maintenant possible de gérer plusieurs abonnement par utilisateur. Auparavant, seulement le dernier abonnement était affiché sur la rubrique des abonnements de vos utilisateurs.",{"type":102,"tag":110,"props":151,"children":153},{"id":152},"des-nouveautés-dans-les-intégrations",[154],{"type":107,"value":155},"Des nouveautés dans les intégrations",{"type":102,"tag":103,"props":157,"children":158},{},[159],{"type":107,"value":160},"Il est maintenant possible d'envoyer des notifications via les outils collaboratifs suivants :",{"type":102,"tag":162,"props":163,"children":164},"ul",{},[165,171,176],{"type":102,"tag":166,"props":167,"children":168},"li",{},[169],{"type":107,"value":170},"Google Chat",{"type":102,"tag":166,"props":172,"children":173},{},[174],{"type":107,"value":175},"Mattermost",{"type":102,"tag":166,"props":177,"children":178},{},[179],{"type":107,"value":180},"Rocket.Chat",{"type":102,"tag":110,"props":182,"children":184},{"id":183},"possibilité-dactiver-la-validation-de-commande-sans-passerelle-de-paiement-site-web",[185,187],{"type":107,"value":186},"Possibilité d'activer la validation de commande sans passerelle de paiement ",{"type":102,"tag":188,"props":189,"children":190},"span",{},[191],{"type":107,"value":192},"SITE WEB",{"type":102,"tag":103,"props":194,"children":195},{},[196],{"type":107,"value":197},"Pour la partie portail client, il est maintenant possible d'activer la caisse sans passerelle de paiement. Cela vous permet de recevoir les commandes de vos utilisateurs sans qu'ils aient effectués le paiement.",{"type":102,"tag":103,"props":199,"children":200},{},[201],{"type":107,"value":202},"Avant cela, il fallait qu'il y ait une passerelle activée (Virement, Stripe etc..) ou alors l'utilisateur pouvait valider sa demande avec l'envoi d'une demande de devis.",{"type":102,"tag":204,"props":205,"children":206},"br",{},[],{"type":102,"tag":103,"props":208,"children":209},{},[210,212,221],{"type":107,"value":211},"Vous pouvez retrouver la liste détaillée des changements de cette nouvelle mise à jour dans la ",{"type":102,"tag":213,"props":214,"children":218},"a",{"href":215,"rel":216},"https://doc.dokos.io/fr/versions/v2_2_0",[217],"nofollow",[219],{"type":107,"value":220},"documentation technique",{"type":107,"value":222},".",{"type":102,"tag":224,"props":225,"children":226},"hr",{},[],{"type":102,"tag":103,"props":228,"children":229},{},[230,232,239],{"type":107,"value":231},"Notre ",{"type":102,"tag":213,"props":233,"children":236},{"href":234,"rel":235},"https://gitlab.com/dokos/dokos/-/boards/966503",[217],[237],{"type":107,"value":238},"feuille de route",{"type":107,"value":240}," est accessible à tous, donc n'hésitez pas à commenter, suggérer et proposer des solutions concrètes pour nous aider à faire évoluer ce logiciel dans le bon sens.",{"title":242,"searchDepth":243,"depth":243,"links":244},"",2,[245,251,252],{"id":112,"depth":243,"text":115,"children":246},[247,249,250],{"id":119,"depth":248,"text":122},3,{"id":130,"depth":248,"text":133},{"id":141,"depth":248,"text":144},{"id":152,"depth":243,"text":155},{"id":183,"depth":243,"text":253},"Possibilité d'activer la validation de commande sans passerelle de paiement SITE WEB","markdown","content:fr:blog:nouveautes-version-2-2.md","content","fr/blog/nouveautes-version-2-2.md","md",[260,260],null,1714114107341]