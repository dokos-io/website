[{"data":1,"prerenderedAt":272},["Reactive",2],{"navigation":3,"/fr/blog/nouveautes-version-2-0":82,"/fr/blog/nouveautes-version-2-0-surround":270},[4,18,22,63,65,68,71,74,77,79],{"title":5,"_path":6,"children":7,"icon":17},"Docs","/docs",[8],{"title":9,"_path":10,"children":11},"Getting Started","/docs/getting-started",[12,14],{"title":13,"_path":10},"Introduction",{"title":15,"_path":16},"Installation","/docs/getting-started/installation","i-heroicons-book-open",{"title":19,"_path":20,"icon":21},"Pricing","/pricing","i-heroicons-credit-card",{"title":23,"_path":24,"children":25,"icon":62},"Blog","/blog",[26,29,32,35,38,41,44,47,50,53,56,59],{"title":27,"_path":28},"Dokos is available on DigitalOcean marketplace","/blog/digitalocean-marketplace",{"title":30,"_path":31},"Dokos, the new open-source ERP","/blog/dokos-new-open-source-erp",{"title":33,"_path":34},"Happy new year 2020","/blog/happy-new-year-2020",{"title":36,"_path":37},"Happy new year 2022","/blog/happy-new-year-2022",{"title":39,"_path":40},"Install party at l'Hermitage","/blog/install-party-hermitage",{"title":42,"_path":43},"New functionalities in version 1.1","/blog/new-functionalities-version-1-1",{"title":45,"_path":46},"New functionalities in version 1.2","/blog/new-functionalities-version-1-2",{"title":48,"_path":49},"New functionalities in version 1.3","/blog/new-functionalities-version-1-3",{"title":51,"_path":52},"New functionalities in version 1.4","/blog/new-functionalities-version-1-4",{"title":54,"_path":55},"New functionalities in version 2.0","/blog/new-functionalities-version-2-0",{"title":57,"_path":58},"New functionalities in version 2.1","/blog/new-functionalities-version-2-1",{"title":60,"_path":61},"New functionalities in version 2.2","/blog/new-functionalities-version-2-2","i-heroicons-newspaper",{"title":19,"_path":64,"icon":21},"/partners",{"title":66,"_path":67},"About us","/about",{"title":69,"_path":70},"Legal","/legal",{"title":72,"_path":73},"Security & Data Protection","/securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":83,"_dir":84,"_draft":85,"_partial":85,"_locale":86,"title":87,"description":88,"name":89,"year":90,"date":91,"id":92,"badge":93,"author":95,"image":96,"body":98,"_type":265,"_id":266,"_source":267,"_file":268,"_extension":269},"/blog/nouveautes-version-2-0","blog",false,"fr","Nouveautés de la version 2.0 de Dokos","Comparaison des devis de fournisseurs, intégrations WooCommerce, LinkedIn, Twitter, YouTube, bilan comptable selon les normes françaises, congés automatisés, planification de production\n","nouveautes-version-2-0","17 juin 2021","2021-06-17","version-2-0",{"label":94},"Actualités","Nicolas Tissot",{"src":97},"/blog/version-2-0/_main.jpg",{"type":99,"children":100,"toc":252},"root",[101,109,116,121,127,132,138,143,148,154,159,165,170,176,181,187,192,198,203,209,214,218,234,238],{"type":102,"tag":103,"props":104,"children":105},"element","p",{},[106],{"type":107,"value":108},"text","Pour cette nouvelle version de Dokos, de nombreux changements ont été apportés à l'ensemble des modules notamment au niveau de l'interface utilisateur.",{"type":102,"tag":110,"props":111,"children":113},"h2",{"id":112},"comparaison-des-devis-de-fournisseurs",[114],{"type":107,"value":115},"Comparaison des devis de fournisseurs",{"type":102,"tag":103,"props":117,"children":118},{},[119],{"type":107,"value":120},"Dès à présent, vous allez pouvoir comparer des devis fournisseurs sur Dokos et scanner les codes-barres dans les reçus d'achat.\nVous allez pouvoir également gérer plusieurs unités de mesure dans vos appels d'offres.",{"type":102,"tag":110,"props":122,"children":124},{"id":123},"affichage-du-bilan-comptable-selon-les-normes-françaises",[125],{"type":107,"value":126},"Affichage du bilan comptable selon les normes françaises",{"type":102,"tag":103,"props":128,"children":129},{},[130],{"type":107,"value":131},"L'affichage du bilan comptable selon les standards français pour les sociétés françaises.\nDe plus, une nouvelle option vient s'ajouter : la facture d'acompte devient possible dans les options de facturation.",{"type":102,"tag":110,"props":133,"children":135},{"id":134},"de-meilleures-intégrations-woocommerce-réseaux-sociaux",[136],{"type":107,"value":137},"De meilleures intégrations : WooCommerce, réseaux sociaux",{"type":102,"tag":103,"props":139,"children":140},{},[141],{"type":107,"value":142},"L'arrivée d'un nouveau connecteur WooCommerce pour votre boutique en ligne (gestion du stock, TVA, factures) améliore la synchronisation entre votre boutique et Dokos.",{"type":102,"tag":103,"props":144,"children":145},{},[146],{"type":107,"value":147},"Vous avez aussi la possibilité de configurer des posts pour vos réseaux sociaux LinkedIn, Twitter et même voir vos statistiques sur YouTube.",{"type":102,"tag":110,"props":149,"children":151},{"id":150},"nouvelles-options-dimpression",[152],{"type":107,"value":153},"Nouvelles options d'impression",{"type":102,"tag":103,"props":155,"children":156},{},[157],{"type":107,"value":158},"Des nouvelles options d'impression sont disponibles pour vos documents transactionnels dans Dokos (Devis, Commande, Facture).",{"type":102,"tag":110,"props":160,"children":162},{"id":161},"un-nouveau-module-lieu",[163],{"type":107,"value":164},"Un nouveau module Lieu",{"type":102,"tag":103,"props":166,"children":167},{},[168],{"type":107,"value":169},"Ce nouveau module permet la réservation d'articles, avec la possibilité de confirmer la réservation de l'article dès que le paiement est traité.",{"type":102,"tag":110,"props":171,"children":173},{"id":172},"des-règles-de-vente-personnalisables",[174],{"type":107,"value":175},"Des règles de vente personnalisables",{"type":102,"tag":103,"props":177,"children":178},{},[179],{"type":107,"value":180},"Des nouvelles fonctionnalités pour dynamiser vos offres de vente en ajoutant des règles de prix et des règles récursives (2 achetés, 1 gratuit par exemple).",{"type":102,"tag":110,"props":182,"children":184},{"id":183},"un-meilleur-suivi-de-vos-expéditions",[185],{"type":107,"value":186},"Un meilleur suivi de vos expéditions",{"type":102,"tag":103,"props":188,"children":189},{},[190],{"type":107,"value":191},"Nouveau type de document Envoi dans lequel la configuration des paramètres d'envoi de colis est possible. Intégration avec des passerelles d'envoi de colis.",{"type":102,"tag":110,"props":193,"children":195},{"id":194},"automatisez-les-congés-de-vos-équipes",[196],{"type":107,"value":197},"Automatisez les congés de vos équipes",{"type":102,"tag":103,"props":199,"children":200},{},[201],{"type":107,"value":202},"Vous pouvez dorénavant allouer automatiquement des congés sur la base d'une politique de congés.\nD'autres nouvelles fonctionnalités de gestion de ressources humaines sont disponibles : promesse d'embauche et congé partiellement payé.",{"type":102,"tag":110,"props":204,"children":206},{"id":205},"une-production-plus-efficace",[207],{"type":107,"value":208},"Une production plus efficace",{"type":102,"tag":103,"props":210,"children":211},{},[212],{"type":107,"value":213},"Planifiez la production des commandes client, les demandes de matériel et les ordres de travail.\nDe plus, vous avez la possibilité de créer des modèles de nomenclatures pour votre production.",{"type":102,"tag":215,"props":216,"children":217},"br",{},[],{"type":102,"tag":103,"props":219,"children":220},{},[221,223,232],{"type":107,"value":222},"Vous pouvez retrouver la liste détaillée des changements de cette nouvelle mise à jour dans la ",{"type":102,"tag":224,"props":225,"children":229},"a",{"href":226,"rel":227},"https://doc.dokos.io/fr/versions/v2_0_0",[228],"nofollow",[230],{"type":107,"value":231},"documentation technique",{"type":107,"value":233},".",{"type":102,"tag":235,"props":236,"children":237},"hr",{},[],{"type":102,"tag":103,"props":239,"children":240},{},[241,243,250],{"type":107,"value":242},"Notre ",{"type":102,"tag":224,"props":244,"children":247},{"href":245,"rel":246},"https://gitlab.com/dokos/dokos/-/boards/966503",[228],[248],{"type":107,"value":249},"feuille de route",{"type":107,"value":251}," est accessible à tous, donc n'hésitez pas à commenter, suggérer et proposer des solutions concrètes pour nous aider à faire évoluer ce logiciel dans le bon sens.",{"title":253,"searchDepth":254,"depth":254,"links":255},"",2,[256,257,258,259,260,261,262,263,264],{"id":112,"depth":254,"text":115},{"id":123,"depth":254,"text":126},{"id":134,"depth":254,"text":137},{"id":150,"depth":254,"text":153},{"id":161,"depth":254,"text":164},{"id":172,"depth":254,"text":175},{"id":183,"depth":254,"text":186},{"id":194,"depth":254,"text":197},{"id":205,"depth":254,"text":208},"markdown","content:fr:blog:nouveautes-version-2-0.md","content","fr/blog/nouveautes-version-2-0.md","md",[271,271],null,1714114107351]