securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":83,"_dir":84,"_draft":85,"_partial":85,"_locale":86,"title":87,"description":88,"name":89,"year":90,"date":91,"id":92,"badge":93,"author":95,"image":96,"body":98,"_type":387,"_id":388,"_source":389,"_file":390,"_extension":391},"/blog/nouveautes-version-3-0","blog",false,"fr","Nouveautés de la version 3.0 de Dokos","Découvrez les nouveautés de la nouvelle version de Dokos 3.0. Une interface remise à jour, des espaces de travail plus facile à gérer, apparition des onglets dans les documents et bien plus.\n","nouveautes-version-3-0","11 octobre 2022","2022-10-11","version-3-0",{"label":94},"Actualités","Nicolas Tissot",{"src":97},"/blog/version-3-0/_main.jpg",{"type":99,"children":100,"toc":370},"root",[101,109,126,133,140,145,158,164,169,175,180,198,204,210,215,238,258,264,287,293,313,319,324,330,335,339,352,356],{"type":102,"tag":103,"props":104,"children":105},"element","p",{},[106],{"type":107,"value":108},"text","Cette version 3.0 de Dokos est basée sur la version 14 de Frappe/ERPNext. Vous allez découvrir les nouvelles fonctionnalités de la plateforme et vous pourrez retrouver tous les détails sur notre documentation.",{"type":102,"tag":110,"props":111,"children":112},"ul",{},[113],{"type":102,"tag":114,"props":115,"children":116},"li",{},[117],{"type":102,"tag":118,"props":119,"children":123},"a",{"href":120,"rel":121},"https://doc.dokos.io/fr/versions/v3_0_0",[122],"nofollow",[124],{"type":107,"value":125},"Documentation détaillé de la Version 3.0",{"type":102,"tag":127,"props":128,"children":130},"h2",{"id":129},"les-évolutions-graphiques-de-dokos",[131],{"type":107,"value":132},"Les évolutions graphiques de Dokos",{"type":102,"tag":134,"props":135,"children":137},"h3",{"id":136},"nouvelle-apparence-visuelle-et-navigation-améliorée",[138],{"type":107,"value":139},"Nouvelle apparence visuelle et navigation améliorée",{"type":102,"tag":103,"props":141,"children":142},{},[143],{"type":107,"value":144},"Dokos fait peau neuve sur son apparence graphique.\nLa colonne de gauche avec l'ensemble des espaces de travail n'est plus présente. Utilisez le reccourcis suivant pour retrouver un écran avec tous les espaces :",{"type":102,"tag":110,"props":146,"children":147},{},[148,153],{"type":102,"tag":114,"props":149,"children":150},{},[151],{"type":107,"value":152},"Windows : CRTL + G",{"type":102,"tag":114,"props":154,"children":155},{},[156],{"type":107,"value":157},"Mac : Commande + G",{"type":102,"tag":134,"props":159,"children":161},{"id":160},"apparition-des-onglets-dans-les-documents",[162],{"type":107,"value":163},"Apparition des onglets dans les documents",{"type":102,"tag":103,"props":165,"children":166},{},[167],{"type":107,"value":168},"Les documents sont structurés d'une nouvelle façon avec l'apparition des onglets.\nPlus facile et plus rapide pour accéder à toutes les rubriques d'un document.",{"type":102,"tag":134,"props":170,"children":172},{"id":171},"des-espaces-de-travail-facilement-personnalisable",[173],{"type":107,"value":174},"Des espaces de travail facilement personnalisable",{"type":102,"tag":103,"props":176,"children":177},{},[178],{"type":107,"value":179},"Utilisez facilement le constructeur intégré pour construire vos espaces de travail. Faites glisser et déplacez facilement les composants de vos espaces.",{"type":102,"tag":110,"props":181,"children":182},{},[183,188,193],{"type":102,"tag":114,"props":184,"children":185},{},[186],{"type":107,"value":187},"Définissez des titres pour les sections et les blocs de lien",{"type":102,"tag":114,"props":189,"children":190},{},[191],{"type":107,"value":192},"Agrandissez, réduisez ou même déplacez les sections comme vous le souhaitez",{"type":102,"tag":114,"props":194,"children":195},{},[196],{"type":107,"value":197},"Ajoutez et/ou supprimer des liens directs à des documents selon vos usages",{"type":102,"tag":127,"props":199,"children":201},{"id":200},"découvrez-les-principales-améliorations-dans-les-modules-de-dokos",[202],{"type":107,"value":203},"Découvrez les principales améliorations dans les modules de Dokos",{"type":102,"tag":134,"props":205,"children":207},{"id":206},"les-évolutions-dans-le-module-crm",[208],{"type":107,"value":209},"Les évolutions dans le module CRM",{"type":102,"tag":103,"props":211,"children":212},{},[213],{"type":107,"value":214},"Vous aurez un nouveau type de document qui va vous permettre de mieux suivre les personnes morales avec les onglets suivants :",{"type":102,"tag":110,"props":216,"children":217},{},[218,223,228,233],{"type":102,"tag":114,"props":219,"children":220},{},[221],{"type":107,"value":222},"Vue d'ensemble pour remplir les informations générales comme le Nom de la société, la part de marché, le nombre d'employé, le revenu annuel.",{"type":102,"tag":114,"props":224,"children":225},{},[226],{"type":107,"value":227},"Adresses et contact",{"type":102,"tag":114,"props":229,"children":230},{},[231],{"type":107,"value":232},"Pistes (Anciennement Prospect)",{"type":102,"tag":114,"props":234,"children":235},{},[236],{"type":107,"value":237},"Opportunités",{"type":102,"tag":103,"props":239,"children":240},{},[241,243,249,251,256],{"type":107,"value":242},"Comme indiqué ci-dessus, le type de document ",{"type":102,"tag":244,"props":245,"children":246},"strong",{},[247],{"type":107,"value":248},"Prospect",{"type":107,"value":250}," est renommé en ",{"type":102,"tag":244,"props":252,"children":253},{},[254],{"type":107,"value":255},"Piste",{"type":107,"value":257},"\nEt vous allez retouver des sections pour gérer les activités et les notes dans les pistes, prospects et opportunités.",{"type":102,"tag":134,"props":259,"children":261},{"id":260},"les-évolutions-dans-le-module-de-gestion-du-site-web",[262],{"type":107,"value":263},"Les évolutions dans le module de gestion du Site web",{"type":102,"tag":110,"props":265,"children":266},{},[267,272,277,282],{"type":102,"tag":114,"props":268,"children":269},{},[270],{"type":107,"value":271},"La présence d'un nouveau bloc web Discussions pour autoriser les discussions sur votre site web",{"type":102,"tag":114,"props":273,"children":274},{},[275],{"type":107,"value":276},"Formulaires web à plusieurs étapes grâce à l'ajout de sauts de page",{"type":102,"tag":114,"props":278,"children":279},{},[280],{"type":107,"value":281},"Des options de recherche dans le site E-Commerce",{"type":102,"tag":114,"props":283,"children":284},{},[285],{"type":107,"value":286},"Nouvelle page de réservation de créneaux sur le site web",{"type":102,"tag":134,"props":288,"children":290},{"id":289},"les-évolutions-dans-le-module-des-ressources-humaines",[291],{"type":107,"value":292},"Les évolutions dans le module des Ressources Humaines",{"type":102,"tag":110,"props":294,"children":295},{},[296,308],{"type":102,"tag":114,"props":297,"children":298},{},[299,301],{"type":107,"value":300},"Les modules RH et Paie ont été transférés dans une application dédiée:\n",{"type":102,"tag":118,"props":302,"children":305},{"href":303,"rel":304},"https://gitlab.com/dokos/hrms",[122],[306],{"type":107,"value":307},"Application Ressources Humaines",{"type":102,"tag":114,"props":309,"children":310},{},[311],{"type":107,"value":312},"Créez votre organigramme des employés sur Dokos",{"type":102,"tag":134,"props":314,"children":316},{"id":315},"les-évolutions-dans-le-module-de-production",[317],{"type":107,"value":318},"Les évolutions dans le module de Production",{"type":102,"tag":103,"props":320,"children":321},{},[322],{"type":107,"value":323},"Dès à présent vous pouvez gérer les pertes de production, obtenir une synthèse du plan de production.\nUn nouveau module apparaît également pour la gestion de la sous-traitance.",{"type":102,"tag":134,"props":325,"children":327},{"id":326},"les-évolutions-dans-le-module-de-comptabilité",[328],{"type":107,"value":329},"Les évolutions dans le module de Comptabilité",{"type":102,"tag":103,"props":331,"children":332},{},[333],{"type":107,"value":334},"Il est désormais possible de lier un client à fournisseur avec une comptabilité commune pour les clients/fournisseurs.",{"type":102,"tag":336,"props":337,"children":338},"br",{},[],{"type":102,"tag":103,"props":340,"children":341},{},[342,344,350],{"type":107,"value":343},"Vous pouvez retrouver la liste détaillée des changements de cette nouvelle mise à jour dans la ",{"type":102,"tag":118,"props":345,"children":347},{"href":120,"rel":346},[122],[348],{"type":107,"value":349},"documentation technique",{"type":107,"value":351},".",{"type":102,"tag":353,"props":354,"children":355},"hr",{},[],{"type":102,"tag":103,"props":357,"children":358},{},[359,361,368],{"type":107,"value":360},"Notre ",{"type":102,"tag":118,"props":362,"children":365},{"href":363,"rel":364},"https://gitlab.com/dokos/dokos/-/boards/966503",[122],[366],{"type":107,"value":367},"feuille de route",{"type":107,"value":369}," est accessible à tous, donc n'hésitez pas à commenter, suggérer et proposer des solutions concrètes pour nous aider à faire évoluer ce logiciel dans le bon sens.",{"title":371,"searchDepth":372,"depth":372,"links":373},"",2,[374,380],{"id":129,"depth":372,"text":132,"children":375},[376,378,379],{"id":136,"depth":377,"text":139},3,{"id":160,"depth":377,"text":163},{"id":171,"depth":377,"text":174},{"id":200,"depth":372,"text":203,"children":381},[382,383,384,385,386],{"id":206,"depth":377,"text":209},{"id":260,"depth":377,"text":263},{"id":289,"depth":377,"text":292},{"id":315,"depth":377,"text":318},{"id":326,"depth":377,"text":329},"markdown","content:fr:blog:nouveautes-version-3-0.md","content","fr/blog/nouveautes-version-3-0.md","md",[393,393],null,1714114107189]