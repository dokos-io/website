rivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":83,"_dir":84,"_draft":85,"_partial":85,"_locale":86,"title":87,"description":88,"name":89,"year":90,"date":91,"id":92,"badge":93,"author":95,"image":96,"body":98,"_type":235,"_id":236,"_source":237,"_file":238,"_extension":239},"/blog/bonne-annee-2020","blog",false,"fr","Bonne année 2020","Toute l'équipe de Dokos vous souhaite une excellente année 2020 ! 🎊\n","bonne-annee-2020","31 décembre 2019","2019-12-31","new-year-2020",{"label":94},"Actualités","Charles-Henri Decultot",{"src":97},"/blog/new-year-2020/_main.jpg",{"type":99,"children":100,"toc":231},"root",[101,109,144,181,215,226],{"type":102,"tag":103,"props":104,"children":105},"element","p",{},[106],{"type":107,"value":108},"text","L'année s'achève, il est temps de faire un petit point avant d'entamer une nouvelle décennie qui s'annonce palpitante !",{"type":102,"tag":103,"props":110,"children":111},{},[112,114,120,122,126,128,131,133,137,139,142],{"type":107,"value":113},"2019 a été une année charnière, avec la création de ",{"type":102,"tag":115,"props":116,"children":117},"strong",{},[118],{"type":107,"value":119},"Dokos",{"type":107,"value":121}," et son lancement officiel au mois d'octobre.",{"type":102,"tag":123,"props":124,"children":125},"br",{},[],{"type":107,"value":127},"\nVous êtes déjà plusieurs dizaines d'entreprises à nous faire confiance et à utiliser le logiciel pour gérer votre activité au quotidien et nous vous en remercions du fond du coeur.",{"type":102,"tag":123,"props":129,"children":130},{},[],{"type":107,"value":132},"\nLes trois premières versions de ",{"type":102,"tag":115,"props":134,"children":135},{},[136],{"type":107,"value":119},{"type":107,"value":138}," nous ont déjà permis d'apporter des améliorations à un certain nombre de fonctionnalités, dont l'interface utilisateur, les calendriers, le centre de notification ou les abonnements et leur intégration avec Stripe et GoCardless.",{"type":102,"tag":123,"props":140,"children":141},{},[],{"type":107,"value":143},"\nNous avons également pu en créer de nouvelles comme les réservations d'articles qui permettent à plusieurs Tiers Lieux de gérer leurs réservations d'espaces ou de ressources.",{"type":102,"tag":103,"props":145,"children":146},{},[147,149,152,154,157,159,162,164,168,170,173,175,179],{"type":107,"value":148},"Le travail ne fait que commencer et nous avons déjà plusieurs gros projets pour 2020.",{"type":102,"tag":123,"props":150,"children":151},{},[],{"type":107,"value":153},"\nEn ce début d'année la priorité sera donnée à l'amélioration des processus comptables pour faciliter la saisie, réduire le risque d'erreur et améliorer le processus de clôture.",{"type":102,"tag":123,"props":155,"children":156},{},[],{"type":107,"value":158},"\nDes fonctionnalités locales, notamment spécifiques à la France, devraient également voir le jour au cours de l'année.",{"type":102,"tag":123,"props":160,"children":161},{},[],{"type":107,"value":163},"\nNous souhaitons également faciliter le processus d'installation de ",{"type":102,"tag":115,"props":165,"children":166},{},[167],{"type":107,"value":119},{"type":107,"value":169}," pour permettre au plus grand nombre de pouvoir l'installer et l'utiliser pour gérer leur entreprise.",{"type":102,"tag":123,"props":171,"children":172},{},[],{"type":107,"value":174},"\nCeci sans oublier de multiples améliorations dans chacun des 33 modules qui composent ",{"type":102,"tag":115,"props":176,"children":177},{},[178],{"type":107,"value":119},{"type":107,"value":180},".",{"type":102,"tag":103,"props":182,"children":183},{},[184,186,189,191,200,202,205,207,213],{"type":107,"value":185},"Notre objectif principal est avant tout de vous aider à résoudre les problèmes que vous rencontrez au quotidien.",{"type":102,"tag":123,"props":187,"children":188},{},[],{"type":107,"value":190},"\nC'est pour cela que notre ",{"type":102,"tag":192,"props":193,"children":197},"a",{"href":194,"rel":195},"https://gitlab.com/dokos/dokos/-/boards/966503",[196],"nofollow",[198],{"type":107,"value":199},"plan de route",{"type":107,"value":201}," est évolutif et collaboratif.",{"type":102,"tag":123,"props":203,"children":204},{},[],{"type":107,"value":206},"\nParticipez à sa ",{"type":102,"tag":192,"props":208,"children":210},{"href":194,"rel":209},[196],[211],{"type":107,"value":212},"construction",{"type":107,"value":214},", votez pour les fonctionnalités qui sont les plus importantes pour vous et nous ferons notre possible pour améliorer le logiciel en fonction de vos besoins.",{"type":102,"tag":103,"props":216,"children":217},{},[218,220,224],{"type":107,"value":219},"C'est grâce à votre investissement à tous que nous pourrons construire une communauté open-source plus grande autour de ",{"type":102,"tag":115,"props":221,"children":222},{},[223],{"type":107,"value":119},{"type":107,"value":225}," en 2020 !",{"type":102,"tag":103,"props":227,"children":228},{},[229],{"type":107,"value":230},"Nous vous souhaitons une excellente année 2020 !!! 🎊",{"title":232,"searchDepth":233,"depth":233,"links":234},"",2,[],"markdown","content:fr:blog:bonne-annee-2020.md","content","fr/blog/bonne-annee-2020.md","md",[241,241],null,1714114107414]