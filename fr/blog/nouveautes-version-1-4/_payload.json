securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":83,"_dir":84,"_draft":85,"_partial":85,"_locale":86,"title":87,"description":88,"name":89,"year":90,"date":91,"id":92,"badge":93,"author":95,"image":96,"body":98,"_type":233,"_id":234,"_source":235,"_file":236,"_extension":237},"/blog/nouveautes-version-1-4","blog",false,"fr","Nouveautés de la version 1.4","Amortissement linéaire sur 360 jours, démo traduite en français, vue en carte et conservation des données lors d'un renommage au menu de la v1.4\n","nouveautes-version-1-4","26 avril 2020","2020-04-26","version-1-4",{"label":94},"Actualités","Charles-Henri Decultot",{"src":97},"/blog/version-1-4/_main.jpg",{"type":99,"children":100,"toc":225},"root",[101,109,116,133,139,160,166,176,184,190,195,198,200,205,209],{"type":102,"tag":103,"props":104,"children":105},"element","p",{},[106],{"type":107,"value":108},"text","Nous sommes heureux de vous proposer une mise à jour mineure de Dokos pour patienter pendant que nous travaillons à une mise à jour majeure pour les mois qui viennent.\nQuatre principales nouveautés viennent enrichir le logiciel.",{"type":102,"tag":110,"props":111,"children":113},"h2",{"id":112},"nouvelle-méthode-damortissement",[114],{"type":107,"value":115},"Nouvelle méthode d'amortissement",{"type":102,"tag":103,"props":117,"children":118},{},[119,125,127,131],{"type":102,"tag":120,"props":121,"children":122},"em",{},[123],{"type":107,"value":124},"Dokos",{"type":107,"value":126}," est désormais capable de calculer un amortissement linéaire au prorata sur 360 jours.",{"type":102,"tag":128,"props":129,"children":130},"br",{},[],{"type":107,"value":132},"\nC'était une fonctionnalité manquante en France où c'est la méthode d'amortissement la plus utilisée.",{"type":102,"tag":110,"props":134,"children":136},{"id":135},"la-démo-peut-être-générée-en-français-et-en-anglais",[137],{"type":107,"value":138},"La démo peut être générée en français et en anglais",{"type":102,"tag":103,"props":140,"children":141},{},[142,144,148,150,153,155,158],{"type":107,"value":143},"Il est désormais possible de choisir la langue de génération d'une démo de ",{"type":102,"tag":120,"props":145,"children":146},{},[147],{"type":107,"value":124},{"type":107,"value":149},".",{"type":102,"tag":128,"props":151,"children":152},{},[],{"type":107,"value":154},"\nA ce stade nous avons traduit la démo originale d'ERPNext en français et nous comptons ajouter des données plus locales au cours des mois qui viennent.",{"type":102,"tag":128,"props":156,"children":157},{},[],{"type":107,"value":159},"\nCette étape technique permet également d'ajouter des données de démo dans d'autres langues à l'avenir.",{"type":102,"tag":110,"props":161,"children":163},{"id":162},"vue-en-carte",[164],{"type":107,"value":165},"Vue en carte",{"type":102,"tag":103,"props":167,"children":168},{},[169,171,174],{"type":107,"value":170},"Un nouveau type de vue \"Carte\" permet d'afficher vos adresses sur une carte du monde et d'appliquer tous les filtres que vous souhaitez comme avec n'importe quelle autre vue.",{"type":102,"tag":128,"props":172,"children":173},{},[],{"type":107,"value":175},"\nCe nouveau type de vue nécessite l'activation de l'API Google Maps pour récupérer les données de géolocalisation de chaque adresse.",{"type":102,"tag":103,"props":177,"children":178},{},[179],{"type":102,"tag":180,"props":181,"children":183},"img",{"alt":165,"src":182},"/images/blog/version-1-4/map_view.png",[],{"type":102,"tag":110,"props":185,"children":187},{"id":186},"conservation-des-données-de-renommage-de-document",[188],{"type":107,"value":189},"Conservation des données de renommage de document",{"type":102,"tag":103,"props":191,"children":192},{},[193],{"type":107,"value":194},"Désormais lorsqu'un document est renommé, cette information est conservée dans un type de document spécifique - Documents renommé - qui est facilement requêtable à des fins d'audit.",{"type":102,"tag":128,"props":196,"children":197},{},[],{"type":107,"value":199},"  \n",{"type":102,"tag":103,"props":201,"children":202},{},[203],{"type":107,"value":204},"L'image Digital Ocean correspondant à cette nouvelle version sera bientôt disponible et la mise à jour de notre cloud aura lieu dans les jours à venir.",{"type":102,"tag":206,"props":207,"children":208},"hr",{},[],{"type":102,"tag":103,"props":210,"children":211},{},[212,214,223],{"type":107,"value":213},"Notre ",{"type":102,"tag":215,"props":216,"children":220},"a",{"href":217,"rel":218},"https://gitlab.com/dokos/dokos/-/boards/966503",[219],"nofollow",[221],{"type":107,"value":222},"feuille de route",{"type":107,"value":224}," est accessible à tous, donc n'hésitez pas à commenter, suggérer et proposer des solutions concrètes pour nous aider à faire évoluer ce logiciel dans le bon sens.",{"title":226,"searchDepth":227,"depth":227,"links":228},"",2,[229,230,231,232],{"id":112,"depth":227,"text":115},{"id":135,"depth":227,"text":138},{"id":162,"depth":227,"text":165},{"id":186,"depth":227,"text":189},"markdown","content:fr:blog:nouveautes-version-1-4.md","content","fr/blog/nouveautes-version-1-4.md","md",[239,239],null,1714114107364]