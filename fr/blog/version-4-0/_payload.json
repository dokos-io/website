title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":83,"_dir":84,"_draft":85,"_partial":85,"_locale":86,"title":87,"description":88,"name":89,"year":90,"date":91,"id":89,"badge":92,"author":94,"image":95,"body":97,"_type":515,"_id":516,"_source":517,"_file":518,"_extension":519},"/blog/version-4-0","blog",false,"fr","Publication de la version 4.0 de Dokos","Découvrez les nouveautés de la version 4 de Dokos.\n","version-4-0","30 novembre 2023","2023-11-30",{"label":93},"Actualités","Charles-Henri Decultot",{"src":96},"/blog/version-4-0/_main.jpg",{"type":98,"children":99,"toc":511},"root",[100,108,113,142,145,147,151,154,159,164,169,180,189,198,206,224,238,247,264,273,282,303,312,325,345,359,368,382,387,421,435,501,506],{"type":101,"tag":102,"props":103,"children":104},"element","p",{},[105],{"type":106,"value":107},"text","Nous sommes ravi de vous annoncer que la version 4 de Dokos a été publiée et est désormais officiellement disponible.",{"type":101,"tag":102,"props":109,"children":110},{},[111],{"type":106,"value":112},"Les nouveaux sites créés sur le cloud Dokos seront automatiquement en version 4 à partir de lundi et nous commencerons la migration des sites hébergés sur le cloud Dokos à partir de la semaine du 11 Décembre. Vous recevrez un email vous prévenant de la date à laquelle vos sites seront migrés dans les prochains jours.",{"type":101,"tag":102,"props":114,"children":115},{},[116,118,122,124,132,135,136],{"type":106,"value":117},"Vous pouvez d'ores et déjà tester cette nouvelle version sur nos deux sites de démo:",{"type":101,"tag":119,"props":120,"children":121},"br",{},[],{"type":106,"value":123},"\n➡️ ",{"type":101,"tag":125,"props":126,"children":130},"a",{"href":127,"rel":128},"https://demo.dokos.cloud/",[129],"nofollow",[131],{"type":106,"value":127},{"type":101,"tag":119,"props":133,"children":134},{},[],{"type":106,"value":123},{"type":101,"tag":125,"props":137,"children":140},{"href":138,"rel":139},"https://tierslieux.dokos.io/",[129],[141],{"type":106,"value":138},{"type":101,"tag":119,"props":143,"children":144},{},[],{"type":106,"value":146},"  \n",{"type":101,"tag":148,"props":149,"children":150},"hr",{},[],{"type":101,"tag":119,"props":152,"children":153},{},[],{"type":101,"tag":102,"props":155,"children":156},{},[157],{"type":106,"value":158},"Cette nouvelle version est basée sur la version 15 de Frappe/ERPNext et reprend ses principales nouveautés.",{"type":101,"tag":102,"props":160,"children":161},{},[162],{"type":106,"value":163},"Cette nouvelle version est le résultat de plus d'un an de travail et de retours précieux de la part de notre communauté d'utilisateurs toujours plus nombreuse. Merci à tous pour votre aide.",{"type":101,"tag":102,"props":165,"children":166},{},[167],{"type":106,"value":168},"Voici un aperçu de quelques nouveautés.",{"type":101,"tag":102,"props":170,"children":171},{},[172,174],{"type":106,"value":173},"✨ ",{"type":101,"tag":175,"props":176,"children":177},"strong",{},[178],{"type":106,"value":179},"L'éditeur de formulaire graphique",{"type":101,"tag":102,"props":181,"children":182},{},[183],{"type":101,"tag":184,"props":185,"children":188},"img",{"alt":186,"src":187},"Editeur de formulaire","/images/blog/version-4/form_builder.png",[],{"type":101,"tag":102,"props":190,"children":191},{},[192,193],{"type":106,"value":173},{"type":101,"tag":175,"props":194,"children":195},{},[196],{"type":106,"value":197},"L'éditeur de flux de travail (Workflows) graphique",{"type":101,"tag":102,"props":199,"children":200},{},[201],{"type":101,"tag":184,"props":202,"children":205},{"alt":203,"src":204},"Editeur de workflows","/images/blog/version-4/workflow_builder.png",[],{"type":101,"tag":102,"props":207,"children":208},{},[209,210],{"type":106,"value":173},{"type":101,"tag":175,"props":211,"children":212},{},[213,215,222],{"type":106,"value":214},"Intégration du design ",{"type":101,"tag":125,"props":216,"children":219},{"href":217,"rel":218},"https://frappeui.com/",[129],[220],{"type":106,"value":221},"Espresso de Frappe",{"type":106,"value":223},", tout en gardant des couleurs.",{"type":101,"tag":102,"props":225,"children":226},{},[227,228,233,236],{"type":106,"value":173},{"type":101,"tag":175,"props":229,"children":230},{},[231],{"type":106,"value":232},"Les écritures de clôture des comptes et des stocks sont générées automatiquement lors de la clôture comptable.",{"type":101,"tag":119,"props":234,"children":235},{},[],{"type":106,"value":237},"\nJusqu'à présent le système recalculait les soldes lors des éditions de rapports. Cela permet d'améliorer la performance lors de la génération des rapports comptables et de stock.",{"type":101,"tag":102,"props":239,"children":240},{},[241,242],{"type":106,"value":173},{"type":101,"tag":175,"props":243,"children":244},{},[245],{"type":106,"value":246},"Il est désormais possible d'activer la réservation du stock au passage d'une commande",{"type":101,"tag":102,"props":248,"children":249},{},[250,251],{"type":106,"value":173},{"type":101,"tag":175,"props":252,"children":253},{},[254,256,262],{"type":106,"value":255},"La gestion des numéros de lot et de série a été améliorée grâce à la création d'un document ",{"type":101,"tag":257,"props":258,"children":259},"em",{},[260],{"type":106,"value":261},"Ensemble de série et lot",{"type":106,"value":263}," qui suit les lignes de commandes jusqu'à la livraison.",{"type":101,"tag":102,"props":265,"children":266},{},[267,268],{"type":106,"value":173},{"type":101,"tag":175,"props":269,"children":270},{},[271],{"type":106,"value":272},"Simplification de la gestion des abonnements: les modèles d'abonnement ont été supprimés et remplacés par des articles récurrents associés à une ou plusieurs périodes de récurrence",{"type":101,"tag":102,"props":274,"children":275},{},[276,277],{"type":106,"value":173},{"type":101,"tag":175,"props":278,"children":279},{},[280],{"type":106,"value":281},"Un outil d'import de FEC permet désormais d'importer des fichiers au format Fichier des Ecritures Comptables pour générer les journaux, clients, fournisseurs, factures et écritures de journal qu'ils contiennent.",{"type":101,"tag":102,"props":283,"children":284},{},[285,286,298,301],{"type":106,"value":173},{"type":101,"tag":175,"props":287,"children":288},{},[289,291],{"type":106,"value":290},"Le module eCommerce a été séparé de Dokos et dispose désormais de sa propre application ",{"type":101,"tag":125,"props":292,"children":295},{"href":293,"rel":294},"https://gitlab.com/dokos/webshop",[129],[296],{"type":106,"value":297},"Webshop",{"type":101,"tag":119,"props":299,"children":300},{},[],{"type":106,"value":302},"\nSi vous utilisez le panier du site web, vous devez installer cette application sur votre site lors de la migration vers la v4. Dans le cas contraire, vous n'avez rien à faire, elle n'est pas nécessaire pour faire fonctionner Dokos.",{"type":101,"tag":102,"props":304,"children":305},{},[306,307],{"type":106,"value":173},{"type":101,"tag":175,"props":308,"children":309},{},[310],{"type":106,"value":311},"Il est désormais possible de proposer plusieurs modes de paiement différents lors des paiements de commandes passées en ligne.",{"type":101,"tag":102,"props":313,"children":314},{},[315,316,321],{"type":106,"value":173},{"type":101,"tag":175,"props":317,"children":318},{},[319],{"type":106,"value":320},"La page de sélection de créneaux sur le site web a également été améliorée",{"type":101,"tag":184,"props":322,"children":324},{"alt":203,"src":323},"/images/blog/version-4/item_booking.png",[],{"type":101,"tag":102,"props":326,"children":327},{},[328,329,341],{"type":106,"value":173},{"type":101,"tag":175,"props":330,"children":331},{},[332,334,339],{"type":106,"value":333},"Une vue ",{"type":101,"tag":257,"props":335,"children":336},{},[337],{"type":106,"value":338},"Gestion de projet",{"type":106,"value":340}," permet de simplifier l'attribution de tâche et l'enregistrement de ses feuilles de temps",{"type":101,"tag":184,"props":342,"children":344},{"alt":203,"src":343},"/images/blog/version-4/project_management.png",[],{"type":101,"tag":102,"props":346,"children":347},{},[348,349,354,357],{"type":106,"value":173},{"type":101,"tag":175,"props":350,"children":351},{},[352],{"type":106,"value":353},"Il est désormais possible d'imprimer une page de couverture à la suite de son format d'impression (devis, factures, etc...).",{"type":101,"tag":119,"props":355,"children":356},{},[],{"type":106,"value":358},"\nCela permet, par exemple, de joindre systématiquement des conditions générales de vente à ses documents de vente sans avoir besoin de les inclure en HTML dans le format d'impression.",{"type":101,"tag":102,"props":360,"children":361},{},[362,363],{"type":106,"value":173},{"type":101,"tag":175,"props":364,"children":365},{},[366],{"type":106,"value":367},"L'application RH gère désormais les congés exceptionnels sur jours ouvrables (Mariage, Décès, etc..)",{"type":101,"tag":102,"props":369,"children":370},{},[371,372,377],{"type":106,"value":173},{"type":101,"tag":175,"props":373,"children":374},{},[375],{"type":106,"value":376},"Il est désormais possible de créer des notifications avec un éditeur visuel",{"type":101,"tag":184,"props":378,"children":381},{"alt":379,"src":380},"Editeur de notification","/images/blog/version-4/notification_builder.png",[],{"type":101,"tag":102,"props":383,"children":384},{},[385],{"type":106,"value":386},"Le détail des changements des principales applications est disponible en cliquant sur les liens suivants:",{"type":101,"tag":102,"props":388,"children":389},{},[390,392,399,402,403,410,413,414],{"type":106,"value":391},"➡️ ",{"type":101,"tag":125,"props":393,"children":396},{"href":394,"rel":395},"https://doc.dokos.io/dodock/versions/v4.x.x/v4_0_0",[129],[397],{"type":106,"value":398},"Framework Dodock",{"type":101,"tag":119,"props":400,"children":401},{},[],{"typ