[{"data":1,"prerenderedAt":229},["Reactive",2],{"navigation":3,"/fr/blog/nouveautes-version-2-1":82,"/fr/blog/nouveautes-version-2-1-surround":227},[4,18,22,63,65,68,71,74,77,79],{"title":5,"_path":6,"children":7,"icon":17},"Docs","/docs",[8],{"title":9,"_path":10,"children":11},"Getting Started","/docs/getting-started",[12,14],{"title":13,"_path":10},"Introduction",{"title":15,"_path":16},"Installation","/docs/getting-started/installation","i-heroicons-book-open",{"title":19,"_path":20,"icon":21},"Pricing","/pricing","i-heroicons-credit-card",{"title":23,"_path":24,"children":25,"icon":62},"Blog","/blog",[26,29,32,35,38,41,44,47,50,53,56,59],{"title":27,"_path":28},"Dokos is available on DigitalOcean marketplace","/blog/digitalocean-marketplace",{"title":30,"_path":31},"Dokos, the new open-source ERP","/blog/dokos-new-open-source-erp",{"title":33,"_path":34},"Happy new year 2020","/blog/happy-new-year-2020",{"title":36,"_path":37},"Happy new year 2022","/blog/happy-new-year-2022",{"title":39,"_path":40},"Install party at l'Hermitage","/blog/install-party-hermitage",{"title":42,"_path":43},"New functionalities in version 1.1","/blog/new-functionalities-version-1-1",{"title":45,"_path":46},"New functionalities in version 1.2","/blog/new-functionalities-version-1-2",{"title":48,"_path":49},"New functionalities in version 1.3","/blog/new-functionalities-version-1-3",{"title":51,"_path":52},"New functionalities in version 1.4","/blog/new-functionalities-version-1-4",{"title":54,"_path":55},"New functionalities in version 2.0","/blog/new-functionalities-version-2-0",{"title":57,"_path":58},"New functionalities in version 2.1","/blog/new-functionalities-version-2-1",{"title":60,"_path":61},"New functionalities in version 2.2","/blog/new-functionalities-version-2-2","i-heroicons-newspaper",{"title":19,"_path":64,"icon":21},"/partners",{"title":66,"_path":67},"About us","/about",{"title":69,"_path":70},"Legal","/legal",{"title":72,"_path":73},"Security & Data Protection","/securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":83,"_dir":84,"_draft":85,"_partial":85,"_locale":86,"title":87,"description":88,"name":89,"year":90,"date":91,"id":92,"badge":93,"author":95,"image":96,"body":98,"_type":222,"_id":223,"_source":224,"_file":225,"_extension":226},"/blog/nouveautes-version-2-1","blog",false,"fr","Nouveautés de la version 2.1 de Dokos","Des nouveautés et mises à jour sur Dokos : Compatibilité, Achats, Framework Dodock, RH, Projets, Ventes et stocks.\n","nouveautes-version-2-1","8 septembre 2021","2021-09-08","version-2-1",{"label":94},"Actualités","Nicolas Tissot",{"src":97},"/blog/version-2-1/_main.jpg",{"type":99,"children":100,"toc":213},"root",[101,109,116,121,127,132,138,143,148,154,159,165,170,175,179,195,199],{"type":102,"tag":103,"props":104,"children":105},"element","p",{},[106],{"type":107,"value":108},"text","Pour cette nouvelle mise à jour de Dokos, quelques changements sont à noter sur plusieurs modules dont la comptabilité, les ventes, les achats, les stocks, les projets et les Ressources Humaines.",{"type":102,"tag":110,"props":111,"children":113},"h2",{"id":112},"création-dun-site-en-multilingues",[114],{"type":107,"value":115},"Création d’un site en multilingues",{"type":102,"tag":103,"props":117,"children":118},{},[119],{"type":107,"value":120},"Vous avez dès à présent la possibilité de créer votre site web en plusieurs langues. Un sélecteur de langue pourra être affiché sur le site pour permettre aux utilisateurs de choisir leur langue de préférence.",{"type":102,"tag":110,"props":122,"children":124},{"id":123},"affichage-du-stock-disponible-dans-les-commandes-fournisseurs",[125],{"type":107,"value":126},"Affichage du stock disponible dans les commandes fournisseurs",{"type":102,"tag":103,"props":128,"children":129},{},[130],{"type":107,"value":131},"Depuis les commandes fournisseurs, vous avez maintenant un champ qui affiche le total du stock disponible. Jusqu’à présent vous deviez aller visualier le stock dans votre inventaire et sur l’article pour voir les disponibilités.",{"type":102,"tag":110,"props":133,"children":135},{"id":134},"créez-des-reçus-dachat-plus-rapidement",[136],{"type":107,"value":137},"Créez des reçus d’achat plus rapidement",{"type":102,"tag":103,"props":139,"children":140},{},[141],{"type":107,"value":142},"Lors de la réception physique des marchandises, matières premières etc.. il vous faut saisir un reçu. Ce reçu sera généralement relié à une commande ou une facture d’achat.",{"type":102,"tag":103,"props":144,"children":145},{},[146],{"type":107,"value":147},"Les reçus d’achat peuvent maintenant être créés à partir de vos factures d’achat.\nPlus besoin de créer manuellement votre reçu d’achat à la suite d’une réception. Faites votre facture d’achat et générer le reçu d’achat simplement.",{"type":102,"tag":110,"props":149,"children":151},{"id":150},"des-nouveaux-rapports-pour-vos-projets",[152],{"type":107,"value":153},"Des nouveaux rapports pour vos projets",{"type":102,"tag":103,"props":155,"children":156},{},[157],{"type":107,"value":158},"Générez de nouveaux rapports pour gérer vos projets. Permettre de visualiser la rentabilité d’un projet et de voir les heures utilisées par les employés.",{"type":102,"tag":110,"props":160,"children":162},{"id":161},"partage-de-document-et-création-de-types-dutilisateurs-pour-les-rh",[163],{"type":107,"value":164},"Partage de document et création de types d’utilisateurs pour les RH",{"type":102,"tag":103,"props":166,"children":167},{},[168],{"type":107,"value":169},"Au niveau du module des Ressources Humaines, vous avez la possibilité de partager le document avec les approbateurs des employés même s’ils n’ont pas accès au document.",{"type":102,"tag":103,"props":171,"children":172},{},[173],{"type":107,"value":174},"De plus, vous pouvez créer un type d’utilisateur spécifique uniquement pour les employés qui doivent accéder au système pour la partie RH.",{"type":102,"tag":176,"props":177,"children":178},"br",{},[],{"type":102,"tag":103,"props":180,"children":181},{},[182,184,193],{"type":107,"value":183},"Vous pouvez retrouver la liste détaillée des changements de cette nouvelle mise à jour dans la ",{"type":102,"tag":185,"props":186,"children":190},"a",{"href":187,"rel":188},"https://doc.dokos.io/fr/versions/v2_1_0",[189],"nofollow",[191],{"type":107,"value":192},"documentation technique",{"type":107,"value":194},".",{"type":102,"tag":196,"props":197,"children":198},"hr",{},[],{"type":102,"tag":103,"props":200,"children":201},{},[202,204,211],{"type":107,"value":203},"Notre ",{"type":102,"tag":185,"props":205,"children":208},{"href":206,"rel":207},"https://gitlab.com/dokos/dokos/-/boards/966503",[189],[209],{"type":107,"value":210},"feuille de route",{"type":107,"value":212}," est accessible à tous, donc n'hésitez pas à commenter, suggérer et proposer des solutions concrètes pour nous aider à faire évoluer ce logiciel dans le bon sens.",{"title":214,"searchDepth":215,"depth":215,"links":216},"",2,[217,218,219,220,221],{"id":112,"depth":215,"text":115},{"id":123,"depth":215,"text":126},{"id":134,"depth":215,"text":137},{"id":150,"depth":215,"text":153},{"id":161,"depth":215,"text":164},"markdown","content:fr:blog:nouveautes-version-2-1.md","content","fr/blog/nouveautes-version-2-1.md","md",[228,228],null,1714114107346]