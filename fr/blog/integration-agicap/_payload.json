[{"data":1,"prerenderedAt":211},["Reactive",2],{"navigation":3,"/fr/blog/integration-agicap":82,"/fr/blog/integration-agicap-surround":209},[4,18,22,63,65,68,71,74,77,79],{"title":5,"_path":6,"children":7,"icon":17},"Docs","/docs",[8],{"title":9,"_path":10,"children":11},"Getting Started","/docs/getting-started",[12,14],{"title":13,"_path":10},"Introduction",{"title":15,"_path":16},"Installation","/docs/getting-started/installation","i-heroicons-book-open",{"title":19,"_path":20,"icon":21},"Pricing","/pricing","i-heroicons-credit-card",{"title":23,"_path":24,"children":25,"icon":62},"Blog","/blog",[26,29,32,35,38,41,44,47,50,53,56,59],{"title":27,"_path":28},"Dokos is available on DigitalOcean marketplace","/blog/digitalocean-marketplace",{"title":30,"_path":31},"Dokos, the new open-source ERP","/blog/dokos-new-open-source-erp",{"title":33,"_path":34},"Happy new year 2020","/blog/happy-new-year-2020",{"title":36,"_path":37},"Happy new year 2022","/blog/happy-new-year-2022",{"title":39,"_path":40},"Install party at l'Hermitage","/blog/install-party-hermitage",{"title":42,"_path":43},"New functionalities in version 1.1","/blog/new-functionalities-version-1-1",{"title":45,"_path":46},"New functionalities in version 1.2","/blog/new-functionalities-version-1-2",{"title":48,"_path":49},"New functionalities in version 1.3","/blog/new-functionalities-version-1-3",{"title":51,"_path":52},"New functionalities in version 1.4","/blog/new-functionalities-version-1-4",{"title":54,"_path":55},"New functionalities in version 2.0","/blog/new-functionalities-version-2-0",{"title":57,"_path":58},"New functionalities in version 2.1","/blog/new-functionalities-version-2-1",{"title":60,"_path":61},"New functionalities in version 2.2","/blog/new-functionalities-version-2-2","i-heroicons-newspaper",{"title":19,"_path":64,"icon":21},"/partners",{"title":66,"_path":67},"About us","/about",{"title":69,"_path":70},"Legal","/legal",{"title":72,"_path":73},"Security & Data Protection","/securityandprivacy",{"title":75,"_path":76},"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":83,"_dir":84,"_draft":85,"_partial":85,"_locale":86,"title":87,"description":88,"name":89,"year":90,"date":91,"id":92,"badge":93,"author":95,"image":96,"body":98,"_type":204,"_id":205,"_source":206,"_file":207,"_extension":208},"/blog/integration-agicap","blog",false,"fr","Intégration avec Agicap","Intégrez Dokos et Agicap pour générez des prévisionnels de trésorerie fiables.\n","integration-agicap","18 septembre 2023","2023-09-18","agicap-integration",{"label":94},"Actualités","Charles-Henri Decultot",{"src":97},"/blog/agicap-integration/_main.jpg",{"type":99,"children":100,"toc":197},"root",[101,109,115,154,161,175,180,192],{"type":102,"tag":103,"props":104,"children":106},"element","h1",{"id":105},"intégration-avec-agicap",[107],{"type":108,"value":87},"text",{"type":102,"tag":110,"props":111,"children":112},"p",{},[113],{"type":108,"value":114},"Nous sommes heureux de vous annoncer une nouvelle intégration enrre Dokos et Agicap, une solution française de prévision de trésorerie.\nCette intégration vise à étendre votre gestion financière en synchronisant vos données transactionnelles présentes dans Dokos avec Agicap pour fiabiliser vos prévisionnels.",{"type":102,"tag":116,"props":117,"children":118},"ul",{},[119,132,143],{"type":102,"tag":120,"props":121,"children":122},"li",{},[123,130],{"type":102,"tag":124,"props":125,"children":127},"h4",{"id":126},"gestion-multi-société",[128],{"type":108,"value":129},"Gestion Multi-société",{"type":108,"value":131},"Agicap permet de créer des prévisionnels de trésorerie pour toutes les entités composant votre organisation. Les données transactionnelles peuvent provenir du même site Dokos ou de sites Dokos séparés.",{"type":102,"tag":120,"props":133,"children":134},{},[135,141],{"type":102,"tag":124,"props":136,"children":138},{"id":137},"gestion-multi-devise",[139],{"type":108,"value":140},"Gestion Multi-devise",{"type":108,"value":142},"Dokos et Agicap permettent la gestion des transactions dans différentes devises de facturation.",{"type":102,"tag":120,"props":144,"children":145},{},[146,152],{"type":102,"tag":124,"props":147,"children":149},{"id":148},"synchronisation-automatique",[150],{"type":108,"value":151},"Synchronisation automatique",{"type":108,"value":153},"La synchronisation entre Dokos et Agicap se fait automatiquement une fois par heure a minima.",{"type":102,"tag":155,"props":156,"children":158},"h3",{"id":157},"agicap",[159],{"type":108,"value":160},"Agicap",{"type":102,"tag":110,"props":162,"children":163},{},[164,166,173],{"type":108,"value":165},"Cette intégration vous permet facilement d'utiliser les fonctions avancées d'Agicap comme payer vos fournisseurs ou relancer vos clients directement depuis son interface.\nPour en savoir plus sur Agicap, prenez rendez-vous avec Floriane Seyre, responsable partenariats : ",{"type":102,"tag":167,"props":168,"children":170},"a",{"href":169},"mailto:floriane.seyve@agicap.com",[171],{"type":108,"value":172},"floriane.seyve@agicap.com",{"type":108,"value":174}," / +33 7 77 34 04 70",{"type":102,"tag":155,"props":176,"children":178},{"id":177},"installation",[179],{"type":108,"value":15},{"type":102,"tag":110,"props":181,"children":182},{},[183,185],{"type":108,"value":184},"Cette intégration est disponible immédiatement : ",{"type":102,"tag":167,"props":186,"children":190},{"href":187,"rel":188},"https://doc.dokos.io/dokos/integrations/agicap",[189],"nofollow",[191],{"type":108,"value":187},{"type":102,"tag":110,"props":193,"children":194},{},[195],{"type":108,"value":196},"Si vous êtes client Dokos Cloud, n'hésitez pas à envoyer un message à notre équipe support pour qu'on la déploie sur votre site.",{"title":198,"searchDepth":199,"depth":199,"links":200},"",2,[201,203],{"id":157,"depth":202,"text":160},3,{"id":177,"depth":202,"text":15},"markdown","content:fr:blog:integration-agicap.md","content","fr/blog/integration-agicap.md","md",[210,210],null,1714114106987]