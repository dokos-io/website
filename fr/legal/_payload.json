":218,"children":219},{},[],{"type":92,"tag":148,"props":221,"children":223},{"href":174,"rel":222},[152],[224],{"type":98,"value":178},{"type":98,"value":226}," ne saurait garantir l'exactitude, la complétude, l'actualité des informations diffusées sur son site.",{"type":92,"tag":117,"props":228,"children":229},{},[],{"type":98,"value":231},"\nEn conséquence, l'utilisateur reconnaît utiliser ces informations sous sa responsabilité exclusive.",{"type":92,"tag":117,"props":233,"children":234},{},[],{"type":98,"value":236},"\nLe site utilise la technologie JavaScript.",{"type":92,"tag":93,"props":238,"children":240},{"id":239},"_3-cookies",[241],{"type":98,"value":242},"3. COOKIES",{"type":92,"tag":101,"props":244,"children":245},{},[246],{"type":98,"value":247},"L'utilisateur est informé que lors de ses visites sur le site, un cookie peut s'installer automatiquement sur son logiciel de navigation.",{"type":92,"tag":101,"props":249,"children":250},{},[251,253,256],{"type":98,"value":252},"Le cookie est un bloc de données qui ne permet pas d'identifier les utilisateurs mais sert à enregistrer des informations relatives à la navigation de celui-ci sur le site.",{"type":92,"tag":117,"props":254,"children":255},{},[],{"type":98,"value":257},"\nLe paramétrage du logiciel de navigation permet d'informer de la présence de cookie et éventuellement, de la refuser.",{"type":92,"tag":101,"props":259,"children":260},{},[261,263,268,270,273],{"type":98,"value":262},"Les utilisateurs du site internet ",{"type":92,"tag":148,"props":264,"children":266},{"href":174,"rel":265},[152],[267],{"type":98,"value":178},{"type":98,"value":269}," sont tenus de respecter les dispositions de la loi n°78-17 du 6 janvier 1978 modifiée, relative à l'informatique, aux fichiers et aux libertés, dont la violation est passible de sanctions pénales.",{"type":92,"tag":117,"props":271,"children":272},{},[],{"type":98,"value":274},"\nIls doivent notamment s'abstenir, s'agissant des informations à caractère personnel auxquelles ils accèdent ou pourraient accéder, de toute collecte, de toute utilisation détournée d'une manière générale, de tout acte susceptible de porter atteinte à la vie privée ou à la réputation des personnes.",{"type":92,"tag":93,"props":276,"children":278},{"id":277},"_4-propriété-intellectuelle",[279],{"type":98,"value":280},"4. PROPRIÉTÉ INTELLECTUELLE",{"type":92,"tag":101,"props":282,"children":283},{},[284,286,291],{"type":98,"value":285},"Les bases de données produites et figurant sur le site web ",{"type":92,"tag":148,"props":287,"children":289},{"href":174,"rel":288},[152],[290],{"type":98,"value":178},{"type":98,"value":292}," sont protégées par les dispositions de la loi du 1er juillet 1998 portant transposition dans le Code de la propriété intellectuelle de la directive du 11 mars 1996 relative à la protection juridique des bases de données.",{"type":92,"tag":101,"props":294,"children":295},{},[296,298,303,305,308,310,315,317,320,322,327,329,332,334,339],{"type":98,"value":297},"Les marques du site ",{"type":92,"tag":148,"props":299,"children":301},{"href":174,"rel":300},[152],[302],{"type":98,"value":178},{"type":98,"value":304}," et de ses partenaires, ainsi que les logos figurant sur le site sont des marques déposées.",{"type":92,"tag":117,"props":306,"children":307},{},[],{"type":98,"value":309},"\nToute reproduction totale ou partielle de ces marques ou de ces logos effectués à partir des éléments du site sans l'autorisation expresse du site ",{"type":92,"tag":148,"props":311,"children":313},{"href":174,"rel":312},[152],[314],{"type":98,"value":178},{"type":98,"value":316}," est donc prohibée au sens du Code de la propriété intellectuelle.",{"type":92,"tag":117,"props":318,"children":319},{},[],{"type":98,"value":321},"\nLe site ",{"type":92,"tag":148,"props":323,"children":325},{"href":174,"rel":324},[152],[326],{"type":98,"value":178},{"type":98,"value":328}," ne saurait être responsable de l'accès par les utilisateurs via les liens hypertextes mis en place dans le cadre du site internet en direction d'autres ressources présentes sur le réseau.",{"type":92,"tag":117,"props":330,"children":331},{},[],{"type":98,"value":333},"\nTout litige en relation avec l'utilisation du site ",{"type":92,"tag":148,"props":335,"children":337},{"href":174,"rel":336},[152],[338],{"type":98,"value":178},{"type":98,"value":340}," est soumis au droit français. L'utilisateur reconnaît la compétence exclusive des tribunaux compétents de Paris.",{"title":83,"searchDepth":342,"depth":342,"links":343},2,[344,345,346,347],{"id":95,"depth":342,"text":99},{"id":158,"depth":342,"text":161},{"id":239,"depth":342,"text":242},{"id":277,"depth":342,"text":280},"markdown","content:fr:legal.md","content","fr/legal.md","md",[354,354],null,1714114105096]