"Services","/selling",{"title":75,"_path":78},"/services",{"title":80,"_path":81},"Termsandconditions","/termsandconditions",{"_path":70,"_dir":83,"_draft":84,"_partial":84,"_locale":85,"title":86,"description":83,"toc":87,"body":88,"_type":348,"_id":349,"_source":350,"_file":351,"_extension":352},"",false,"fr","Mentions Légales",true,{"type":89,"children":90,"toc":341},"root",[91,100,106,156,162,167,237,243,248,258,275,281,293],{"type":92,"tag":93,"props":94,"children":96},"element","h2",{"id":95},"_1-présentation-du-site",[97],{"type":98,"value":99},"text","1. PRÉSENTATION DU SITE",{"type":92,"tag":101,"props":102,"children":103},"p",{},[104],{"type":98,"value":105},"Conformément aux dispositions des articles 6-III et 19 de la loi pour la Confiance dans l'Économie Numérique, nous vous informons que :",{"type":92,"tag":107,"props":108,"children":109},"ul",{},[110,137,142],{"type":92,"tag":111,"props":112,"children":113},"li",{},[114,116,120,122,125,127,130,132,135],{"type":98,"value":115},"Le présent site web est édité par :",{"type":92,"tag":117,"props":118,"children":119},"br",{},[],{"type":98,"value":121},"\nDOKOS SAS",{"type":92,"tag":117,"props":123,"children":124},{},[],{"type":98,"value":126},"\n7B Allée Neuve",{"type":92,"tag":117,"props":128,"children":129},{},[],{"type":98,"value":131},"\n54520 Laxou\nFrance",{"type":92,"tag":117,"props":133,"children":134},{},[],{"type":98,"value":136},"\nRCS : 824 710 776 R.C.S Nancy",{"type":92,"tag":111,"props":138,"children":139},{},[140],{"type":98,"value":141},"Directeur de la publication du site web : Charles-Henri Decultot",{"type":92,"tag":111,"props":143,"children":144},{},[145,147],{"type":98,"value":146},"Le prestataire assurant l'hébergement du site est : ",{"type":92,"tag":148,"props":149,"children":153},"a",{"href":150,"rel":151},"https://www.netlify.com/",[152],"nofollow",[154],{"type":98,"value":155},"Netlify",{"type":92,"tag":93,"props":157,"children":159},{"id":158},"_2-limitation-de-responsabilité",[1